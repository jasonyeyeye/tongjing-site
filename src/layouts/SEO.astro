---
import { locales } from '../utils/i18n';

// Google Analytics Measurement ID (格式: G-XXXXXXXXXX)
// 在 Cloudflare Pages 环境变量中设置 GA_MEASUREMENT_ID
const gaMeasurementId = import.meta.env.GA_MEASUREMENT_ID || 'G-XXXXXXXXXX';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  locale?: string;
  type?: 'website' | 'product';
}

const { title, description, image, canonical, locale = 'en', type = 'website' } = Astro.props;
const siteUrl = 'https://tongjing.example.com';
const defaultImage = `${siteUrl}/og-image.png`;
const currentUrl = canonical ?? Astro.url.href;

const siteNames: Record<string, string> = {
  en: 'TongJing Electronics',
  zh: '同晶电子',
  ja: '同晶電子',
  de: 'TongJing Elektronik',
};

// Generate hreflang URLs
const getHreflangUrl = (loc: string) => {
  // Extract pathname from currentUrl
  const url = new URL(currentUrl);
  const pathname = url.pathname;
  // Remove current locale prefix if present
  const pathWithoutLocale = pathname.replace(/^\/(zh|en|ja|de)/, '') || '/';
  // Return URL with new locale prefix
  const newPath = loc === 'en' ? pathWithoutLocale : `/${loc}${pathWithoutLocale === '/' ? '' : pathWithoutLocale}`;
  return `${url.origin}${newPath}`;
};

// JSON-LD Structured Data
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': type === 'product' ? 'Product' : 'Organization',
  name: siteNames[locale] ?? siteNames.en,
  description,
  url: currentUrl,
  ...(type === 'product' ? {
    image: image ?? defaultImage,
    brand: { '@type': 'Brand', name: 'TongJing' },
    manufacturer: { '@type': 'Organization', name: 'TongJing Electronics' },
  } : {
    logo: `${siteUrl}/favicon.svg`,
    sameAs: [
      'https://www.linkedin.com/company/tongjing',
      'https://github.com/tongjing',
    ],
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: '+86-551-xxxx-xxxx',
      contactType: 'customer service',
      availableLanguage: ['en', 'zh', 'ja', 'de'],
    },
  }),
};
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />
<link rel="canonical" href={currentUrl} />

<!-- Hreflang for multi-language SEO -->
{locales.map((loc) => (
  <link rel="alternate" hreflang={loc} href={getHreflangUrl(loc)} />
))}
<link rel="alternate" hreflang="x-default" href={getHreflangUrl('en')} />

<!-- Open Graph -->
<meta property="og:type" content={type === 'product' ? 'product' : 'website'} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image ?? defaultImage} />
<meta property="og:url" content={currentUrl} />
<meta property="og:site_name" content={siteNames[locale] ?? siteNames.en} />
<meta property="og:locale" content={locale === 'zh' ? 'zh_CN' : locale === 'ja' ? 'ja_JP' : locale === 'de' ? 'de_DE' : 'en_US'} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image ?? defaultImage} />

<!-- Sitemap & Robots -->
<link rel="sitemap" href="/sitemap-index.xml" />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<!-- Google Analytics 4 -->
<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
<script define:vars={{ gaMeasurementId }}>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', gaMeasurementId, {
    page_path: new URL(window.location.href).pathname,
  });
</script>

<title>{title}</title>
