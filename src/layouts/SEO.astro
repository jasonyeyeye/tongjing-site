---
// Google Analytics Measurement ID (format: G-XXXXXXXXXX)
// Set in Cloudflare Pages environment variable GA_MEASUREMENT_ID
const gaMeasurementId = import.meta.env.GA_MEASUREMENT_ID || 'G-XXXXXXXXXX';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'product';
}

const { title, description, image, canonical, type = 'website' } = Astro.props;
const siteUrl = 'https://chinanewchip.com';
const defaultImage = `${siteUrl}/og-image.png`;
const currentUrl = canonical ?? Astro.url.href;

// JSON-LD Structured Data
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': type === 'product' ? 'Product' : 'Organization',
  name: 'China NewChip',
  description,
  url: currentUrl,
  ...(type === 'product' ? {
    image: image ?? defaultImage,
    brand: { '@type': 'Brand', name: 'China NewChip' },
    manufacturer: { '@type': 'Organization', name: 'China NewChip Electronics' },
  } : {
    logo: `${siteUrl}/favicon.svg`,
    sameAs: [
      'https://www.linkedin.com/company/chinanewchip',
      'https://github.com/chinanewchip',
    ],
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: '+86-551-xxxx-xxxx',
      contactType: 'customer service',
      availableLanguage: 'en',
    },
  }),
};
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />
<link rel="canonical" href={currentUrl} />

<!-- Open Graph -->
<meta property="og:type" content={type === 'product' ? 'product' : 'website'} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image ?? defaultImage} />
<meta property="og:url" content={currentUrl} />
<meta property="og:site_name" content="China NewChip" />
<meta property="og:locale" content="en_US" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image ?? defaultImage} />

<!-- Sitemap & Robots -->
<link rel="sitemap" href="/sitemap-index.xml" />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<!-- Google Analytics 4 -->
<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
<script define:vars={{ gaMeasurementId }}>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', gaMeasurementId, {
    page_path: new URL(window.location.href).pathname,
  });
</script>

<title>{title}</title>
