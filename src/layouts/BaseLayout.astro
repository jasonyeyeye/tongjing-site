---
import SEO from './SEO.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'product' | 'article';
  pageType?: 'home' | 'products' | 'brands' | 'about' | 'contact' | 'tools';
}

const { title, description, image, canonical, type, pageType } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <SEO
      title={title}
      description={description}
      image={image}
      canonical={canonical}
      type={type}
      pageType={pageType}
    />
  </head>
  <body class="flex flex-col min-h-screen bg-white text-charcoal">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
