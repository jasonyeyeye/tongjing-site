---
import Input from '../ui/Input.astro';
import Button from '../ui/Button.astro';

interface Props {
  products?: Array<{ model: string; quantity: number }>;
}

const { products = [] } = Astro.props;
---

<div class="bg-white rounded-xl border border-light-gray p-6">
  <h3 class="text-xl font-semibold text-charcoal mb-6">发送询价 / Send Inquiry</h3>
  
  <form class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <Input label="姓名/Name" name="name" required placeholder="张三" />
      <Input label="公司/Company" name="company" required placeholder="XX电子有限公司" />
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <Input label="邮箱/Email" name="email" type="email" required placeholder="name@company.com" />
      <Input label="电话/Phone" name="phone" type="tel" placeholder="+86 XXX XXXX XXXX" />
    </div>

    <!-- Products -->
    <div class="space-y-3">
      <label class="block text-sm font-medium text-charcoal">
        询价产品/Products <span class="text-error">*</span>
      </label>
      <div class="border border-light-gray rounded-lg p-4 space-y-2 min-h-[120px]">
        {products.length === 0 ? (
          <p class="text-mid-gray text-sm text-center py-8">请从产品页添加询价产品</p>
        ) : (
          products.map((p) => (
            <div class="flex items-center justify-between bg-light-gray rounded-lg px-3 py-2">
              <div class="flex items-center gap-2">
                <span class="font-mono text-sm">{p.model}</span>
                <span class="text-mid-gray text-sm">× {p.quantity}</span>
              </div>
              <button type="button" class="text-mid-gray hover:text-error transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          ))
        )}
      </div>
      <button type="button" class="text-sm text-tech-blue hover:underline">
        + 添加更多产品
      </button>
    </div>

    <!-- Message -->
    <div class="space-y-1">
      <label for="message" class="block text-sm font-medium text-charcoal">留言/Message</label>
      <textarea
        id="message"
        name="message"
        rows="4"
        placeholder="请描述您的需求..."
        class="w-full px-4 py-3 rounded-lg border border-light-gray text-charcoal placeholder:text-mid-gray focus:border-tech-blue focus:ring-1 focus:ring-tech-blue transition-colors resize-none"
      ></textarea>
    </div>

    <!-- Submit -->
    <Button variant="primary" size="lg" type="submit" class="w-full">
      发送询价 Send Inquiry
    </Button>
  </form>
</div>
