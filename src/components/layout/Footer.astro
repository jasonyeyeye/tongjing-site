---
import { getLocaleFromUrl, useTranslations } from '../../utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const navItems = [
  { key: 'products', href: `/${locale}/products` },
  { key: 'tools', href: `/${locale}/tools` },
  { key: 'news', href: `/${locale}/news` },
  { key: 'about', href: `/${locale}/about` },
  { key: 'contact', href: `/${locale}/contact` },
];
---

<footer class="bg-deep-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center">
            <span class="text-brand-blue font-bold text-lg">TJ</span>
          </div>
          <span class="text-xl font-bold">TongJing Electronics</span>
        </div>
        <p class="text-mid-gray text-sm leading-relaxed mb-4">
          Hefei TongJing Electronics Co., Ltd.<br>
          Professional manufacturer of crystal resonators, oscillators and RTC modules<br>
          R&D · Automated Production · Global Direct Sales
        </p>
        <div class="flex items-center gap-2 text-mid-gray text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span>+86 551-xxxx-xxxx</span>
        </div>
      </div>

      <!-- Products -->
      <div>
        <h4 class="font-semibold mb-4">{t.nav.products}</h4>
        <ul class="space-y-2 text-sm">
          <li><a href={`/${locale}/products/resonators`} class="text-mid-gray hover:text-crystal-orange transition-colors">{t.product.resonators}</a></li>
          <li><a href={`/${locale}/products/oscillators`} class="text-mid-gray hover:text-crystal-orange transition-colors">{t.product.oscillators}</a></li>
          <li><a href={`/${locale}/products/rtc`} class="text-mid-gray hover:text-crystal-orange transition-colors">{t.product.rtc}</a></li>
          <li><a href={`/${locale}/tools`} class="text-mid-gray hover:text-crystal-orange transition-colors">{t.nav.tools}</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="font-semibold mb-4">Company</h4>
        <ul class="space-y-2 text-sm">
          <li><a href={`/${locale}/about`} class="text-mid-gray hover:text-crystal-orange transition-colors">{t.nav.about}</a></li>
          <li><a href={`/${locale}/news`} class="text-mid-gray hover:text-crystal-orange transition-colors">{t.nav.news}</a></li>
          <li><a href={`/${locale}/contact`} class="text-mid-gray hover:text-crystal-orange transition-colors">{t.nav.contact}</a></li>
        </ul>
      </div>
    </div>

    <!-- Certifications -->
    <div class="mt-8 pt-8 border-t border-charcoal">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <span class="text-sm text-mid-gray">Certifications:</span>
          <div class="flex items-center gap-3">
            <span class="px-2 py-1 bg-charcoal rounded text-xs font-medium">ISO9001</span>
            <span class="px-2 py-1 bg-charcoal rounded text-xs font-medium">RoHS</span>
            <span class="px-2 py-1 bg-charcoal rounded text-xs font-medium">REACH</span>
            <span class="px-2 py-1 bg-charcoal rounded text-xs font-medium">AEC-Q</span>
            <span class="px-2 py-1 bg-charcoal rounded text-xs font-medium">Halogen Free</span>
          </div>
        </div>
        <p class="text-sm text-mid-gray">
          © 2026 TongJing Electronics. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
