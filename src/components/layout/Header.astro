---
import { brands } from '../../data/brands';
import LanguageSwitcher from './LanguageSwitcher.astro';
---

<header class="sticky top-0 z-50 glass border-b border-gray-200/50">
  <!-- Desktop Nav -->
  <div class="hidden md:block">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-[72px]">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-cosmic-400 to-cosmic-600 rounded-xl blur-lg opacity-40 group-hover:opacity-60 transition-opacity duration-300"></div>
            <div class="relative w-10 h-10 bg-gradient-to-br from-cosmic-500 to-cosmic-700 rounded-xl flex items-center justify-center shadow-lg" style="background: linear-gradient(135deg, #2563EB, #1D4ED8)">
              <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2L2 9l10 5 10-5L12 2zm0 18l-10-5 10-5 10 5-10 5zm0-8L2 14l10 5 10-5-10-5z"/>
              </svg>
            </div>
          </div>
          <span class="text-xl font-bold bg-gradient-to-r from-gray-800 to-gray-600 bg-clip-text text-transparent">China NewChip</span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="flex items-center gap-1" aria-label="Main navigation">
          <a href="/" class="nav-link relative px-4 py-2 text-base font-medium text-gray-600 hover:text-cosmic-600 transition-colors duration-200" data-i18n="nav.home">Home</a>
          <a href="/brands" class="nav-link relative px-4 py-2 text-base font-medium text-gray-600 hover:text-cosmic-600 transition-colors duration-200" data-i18n="nav.brands">Brands</a>
          <a href="/products" class="nav-link relative px-4 py-2 text-base font-medium text-gray-600 hover:text-cosmic-600 transition-colors duration-200" data-i18n="nav.products">Products</a>
          <a href="/tools" class="nav-link relative px-4 py-2 text-base font-medium text-gray-600 hover:text-cosmic-600 transition-colors duration-200" data-i18n="nav.tools">Selection Tools</a>
          <a href="/news" class="nav-link relative px-4 py-2 text-base font-medium text-gray-600 hover:text-cosmic-600 transition-colors duration-200" data-i18n="nav.news">News</a>
          <a href="/about" class="nav-link relative px-4 py-2 text-base font-medium text-gray-600 hover:text-cosmic-600 transition-colors duration-200" data-i18n="nav.about">About Us</a>
          <a href="/contact" class="nav-link relative px-4 py-2 text-base font-medium text-gray-600 hover:text-cosmic-600 transition-colors duration-200" data-i18n="nav.contact">Contact</a>
        </nav>

        <!-- Right Actions -->
        <div class="flex items-center gap-3">
          <LanguageSwitcher />
          <a
            href="/contact"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-br from-aurora-400 to-aurora-500 text-white rounded-xl font-medium text-sm shadow-[0_4px_14px_rgba(249,115,22,0.3)] hover:shadow-[0_6px_20px_rgba(249,115,22,0.4)] hover:from-aurora-300 hover:to-aurora-400 transition-all duration-200 active:scale-[0.97]"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <span data-i18n="header.inquiry">Inquiry</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Search Bar -->
    <div class="border-t border-gray-200/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
        <div class="relative">
          <input
            type="search"
            id="header-search"
            placeholder="Search products, brands, or part numbers..."
            data-i18n-placeholder="product.search"
            aria-label="Search"
            autocomplete="off"
            class="w-full h-11 pl-11 pr-4 rounded-xl border border-gray-200 bg-white/80 text-gray-800 placeholder:text-gray-400 focus:border-cosmic-400 focus:ring-4 focus:ring-cosmic-400/10 hover:border-gray-300 transition-all duration-200"
          />
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <div id="search-results" class="hidden absolute top-full left-0 right-0 mt-2 bg-white rounded-xl border border-gray-200 shadow-xl z-50 max-h-96 overflow-y-auto"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div class="md:hidden">
    <div class="flex justify-between items-center h-16 px-4">
      <a href="/" class="flex items-center gap-2">
        <div class="w-9 h-9 bg-gradient-to-br from-cosmic-500 to-cosmic-700 rounded-lg flex items-center justify-center shadow-md" style="background: linear-gradient(135deg, #2563EB, #1D4ED8)">
          <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2L2 9l10 5 10-5L12 2zm0 18l-10-5 10-5 10 5-10 5zm0-8L2 14l10 5 10-5-10-5z"/>
          </svg>
        </div>
        <span class="font-bold text-gray-800">China NewChip</span>
      </a>
      <div class="flex items-center gap-2">
        <LanguageSwitcher />
        <button
          id="mobile-menu-btn"
          class="p-2 rounded-lg hover:bg-gray-100 transition-colors"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Open menu"
        >
          <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Search -->
    <div class="px-4 pb-3">
      <input
        type="search"
        id="mobile-search"
        placeholder="Search..."
        data-i18n-placeholder="product.search"
        class="w-full h-10 pl-10 pr-4 rounded-lg border border-gray-200 bg-white text-gray-800 placeholder:text-gray-400"
      />
    </div>

    <!-- Mobile Menu Drawer -->
    <div id="mobile-menu" class="hidden fixed inset-0 z-50" role="dialog" aria-modal="true" aria-labelledby="mobile-menu-title">
      <div class="absolute inset-0 bg-gray-900/50 backdrop-blur-sm" id="mobile-menu-overlay"></div>
      <div class="absolute right-0 top-0 h-full w-80 max-w-[85vw] bg-white shadow-2xl">
        <div class="flex justify-between items-center p-4 border-b border-gray-100">
          <span id="mobile-menu-title" class="font-bold text-lg bg-gradient-to-r from-cosmic-600 to-cosmic-500 bg-clip-text text-transparent">Menu</span>
          <button id="mobile-menu-close" class="p-2 rounded-lg hover:bg-gray-100 transition-colors" aria-label="Close menu">
            <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <nav class="p-4 space-y-1" aria-label="Mobile navigation">
          <a href="/" class="block px-4 py-3 rounded-xl text-gray-700 hover:bg-gray-50 hover:text-cosmic-600 transition-colors font-medium" data-i18n="nav.home">Home</a>
          <a href="/brands" class="block px-4 py-3 rounded-xl text-gray-700 hover:bg-gray-50 hover:text-cosmic-600 transition-colors font-medium" data-i18n="nav.brands">Brands</a>
          <a href="/products" class="block px-4 py-3 rounded-xl text-gray-700 hover:bg-gray-50 hover:text-cosmic-600 transition-colors font-medium" data-i18n="nav.products">Products</a>
          <a href="/tools" class="block px-4 py-3 rounded-xl text-gray-700 hover:bg-gray-50 hover:text-cosmic-600 transition-colors font-medium" data-i18n="nav.tools">Selection Tools</a>
          <a href="/news" class="block px-4 py-3 rounded-xl text-gray-700 hover:bg-gray-50 hover:text-cosmic-600 transition-colors font-medium" data-i18n="nav.news">News</a>
          <a href="/about" class="block px-4 py-3 rounded-xl text-gray-700 hover:bg-gray-50 hover:text-cosmic-600 transition-colors font-medium" data-i18n="nav.about">About Us</a>
          <a href="/contact" class="block px-4 py-3 rounded-xl text-gray-700 hover:bg-gray-50 hover:text-cosmic-600 transition-colors font-medium" data-i18n="nav.contact">Contact</a>
          <hr class="my-4 border-gray-100" />
          <a
            href="/contact"
            class="w-full flex items-center justify-center gap-2 px-4 py-3.5 bg-gradient-to-br from-aurora-400 to-aurora-500 text-white rounded-xl font-medium shadow-[0_4px_14px_rgba(249,115,22,0.3)]"
          >
            <span data-i18n="header.inquiry">Inquiry</span>
          </a>
        </nav>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-cosmic-500), var(--color-aurora-400));
    border-radius: 1px;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    transform: translateX(-50%);
  }

  .nav-link:hover::after {
    width: calc(100% - 2rem);
  }

  .nav-link:hover {
    color: var(--color-cosmic-600);
  }
</style>

<script>
  // Product data for search
  const searchProducts = [
    { id: 'tongjing-2a-24-000meej-t', model: '2A-24.000MEEJ-T', frequency: '24MHz', package: '2520', category: 'resonator' },
    { id: 'tongjing-2a-26-000meej-t', model: '2A-26.000MEEJ-T', frequency: '26MHz', package: '2520', category: 'resonator' },
    { id: 'tongjing-3a-16-000meej-t', model: '3A-16.000MEEJ-T', frequency: '16MHz', package: '3225', category: 'resonator' },
    { id: 'tongjing-5a-16-000meej-t', model: '5A-16.000MEEJ-T', frequency: '16MHz', package: '5032', category: 'oscillator' },
    { id: 'tongjing-7a-25-000meej-t', model: '7A-25.000MEEJ-T', frequency: '25MHz', package: '7050', category: 'oscillator' },
  ];

  function performSearch(query: string) {
    if (!query || query.length < 2) return [];
    const q = query.toLowerCase();
    return searchProducts.filter(p =>
      p.model.toLowerCase().includes(q) ||
      p.frequency.includes(q) ||
      p.package.includes(q)
    ).slice(0, 8);
  }

  function renderSearchResults(results: typeof searchProducts, query: string) {
    const container = document.getElementById('search-results');
    if (!container) return;
    if (results.length === 0) { container.classList.add('hidden'); return; }
    container.innerHTML = results.map(p => `
      <a href="/products/${p.id}" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors border-b border-gray-100 last:border-0">
        <svg class="w-5 h-5 text-cosmic-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
        </svg>
        <div class="flex-1 min-w-0">
          <p class="font-medium text-gray-800 font-mono">${p.model}</p>
          <p class="text-sm text-gray-500">${p.frequency} · ${p.package}</p>
        </div>
      </a>
    `).join('');
    container.classList.remove('hidden');
  }

  // Search input handling
  const searchInput = document.getElementById('header-search') as HTMLInputElement;
  let timeout: ReturnType<typeof setTimeout>;
  searchInput?.addEventListener('input', (e) => {
    clearTimeout(timeout);
    timeout = setTimeout(() => {
      const results = performSearch((e.target as HTMLInputElement).value);
      renderSearchResults(results, (e.target as HTMLInputElement).value);
    }, 150);
  });
  searchInput?.addEventListener('blur', () => setTimeout(() => document.getElementById('search-results')?.classList.add('hidden'), 200));

  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menuClose = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => { mobileMenu?.classList.remove('hidden'); document.body.style.overflow = 'hidden'; });
  menuClose?.addEventListener('click', () => { mobileMenu?.classList.add('hidden'); document.body.style.overflow = ''; });
  document.getElementById('mobile-menu-overlay')?.addEventListener('click', () => { mobileMenu?.classList.add('hidden'); document.body.style.overflow = ''; });
</script>