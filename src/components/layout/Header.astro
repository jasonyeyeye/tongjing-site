---
import { useTranslations } from '../../utils/i18n';
import { brands } from '../../data/brands';

const t = useTranslations();

const navItems = [
  { key: 'home', href: '/' },
  { key: 'brands', href: '/brands' },
  { key: 'products', href: '/products' },
  { key: 'tools', href: '/tools' },
  { key: 'news', href: '/news' },
  { key: 'about', href: '/about' },
  { key: 'contact', href: '/contact' },
];

const currentBrand = brands[0];
---

<header class="sticky top-0 z-50 glass border-b border-gray-200/50">
  <!-- Desktop Nav -->
  <div class="hidden md:block">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-[72px]">
        <!-- Logo - Left aligned -->
        <a href="/" class="flex items-center gap-3 group">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-cosmic-400 to-cosmic-600 rounded-xl blur-lg opacity-40 group-hover:opacity-60 transition-opacity duration-300"></div>
            <div class="relative w-10 h-10 bg-gradient-to-br from-cosmic-500 to-cosmic-700 rounded-xl flex items-center justify-center shadow-lg" style={`background: linear-gradient(135deg, ${currentBrand.primaryColor}, ${currentBrand.primaryColor}dd)`}>
              <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2L2 9l10 5 10-5L12 2zm0 18l-10-5 10-5 10 5-10 5zm0-8L2 14l10 5 10-5-10-5z"/>
              </svg>
            </div>
          </div>
          <span class="text-xl font-bold bg-gradient-to-r from-gray-800 to-gray-600 bg-clip-text text-transparent">China NewChip</span>
        </a>

        <!-- Desktop Navigation - Center -->
        <nav class="flex items-center gap-1" aria-label="Main navigation">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="nav-link relative px-4 py-2 text-base font-medium text-gray-600 hover:text-cosmic-600 transition-colors duration-200"
            >
              {t.nav[item.key as keyof typeof t.nav]}
            </a>
          ))}
        </nav>

        <!-- Right Actions -->
        <div class="flex items-center gap-3">
          <a
            href="/contact"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-br from-aurora-400 to-aurora-500 text-white rounded-xl font-medium text-sm shadow-[0_4px_14px_rgba(249,115,22,0.3)] hover:shadow-[0_6px_20px_rgba(249,115,22,0.4)] hover:from-aurora-300 hover:to-aurora-400 transition-all duration-200 active:scale-[0.97]"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <span>Inquiry</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Search Bar -->
    <div class="border-t border-gray-200/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
        <div class="relative">
          <input
            type="search"
            id="header-search"
            placeholder={t.product.search}
            aria-label={t.product.search}
            autocomplete="off"
            class="w-full h-11 pl-11 pr-4 rounded-xl border border-gray-200 bg-white/80 text-gray-800 placeholder:text-gray-400 focus:border-cosmic-400 focus:ring-4 focus:ring-cosmic-400/10 hover:border-gray-300 transition-all duration-200"
          />
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <!-- Search Results Dropdown -->
          <div id="search-results" class="hidden absolute top-full left-0 right-0 mt-2 bg-white rounded-xl border border-gray-200 shadow-xl z-50 max-h-96 overflow-y-auto">
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div class="md:hidden">
    <div class="flex justify-between items-center h-16 px-4">
      <a href="/" class="flex items-center gap-2">
        <div class="w-9 h-9 bg-gradient-to-br from-cosmic-500 to-cosmic-700 rounded-lg flex items-center justify-center shadow-md" style={`background: linear-gradient(135deg, ${currentBrand.primaryColor}, ${currentBrand.primaryColor}dd)`}>
          <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2L2 9l10 5 10-5L12 2zm0 18l-10-5 10-5 10 5-10 5zm0-8L2 14l10 5 10-5-10-5z"/>
          </svg>
        </div>
        <span class="font-bold text-gray-800">China NewChip</span>
      </a>
      <button
        id="mobile-menu-btn"
        class="p-2 rounded-lg hover:bg-gray-100 transition-colors"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Search -->
    <div class="px-4 pb-3">
      <input
        type="search"
        id="mobile-search"
        placeholder={t.product.search}
        class="w-full h-10 pl-10 pr-4 rounded-lg border border-gray-200 bg-white text-gray-800 placeholder:text-gray-400"
      />
    </div>

    <!-- Mobile Menu Drawer -->
    <div id="mobile-menu" class="hidden fixed inset-0 z-50" role="dialog" aria-modal="true" aria-labelledby="mobile-menu-title">
      <div class="absolute inset-0 bg-gray-900/50 backdrop-blur-sm" id="mobile-menu-overlay"></div>
      <div class="absolute right-0 top-0 h-full w-80 max-w-[85vw] bg-white shadow-2xl">
        <div class="flex justify-between items-center p-4 border-b border-gray-100">
          <span id="mobile-menu-title" class="font-bold text-lg bg-gradient-to-r from-cosmic-600 to-cosmic-500 bg-clip-text text-transparent">Menu</span>
          <button id="mobile-menu-close" class="p-2 rounded-lg hover:bg-gray-100 transition-colors" aria-label="Close menu">
            <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <nav class="p-4 space-y-1" aria-label="Mobile navigation">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="block px-4 py-3 rounded-xl text-gray-700 hover:bg-gray-50 hover:text-cosmic-600 transition-colors font-medium"
            >
              {t.nav[item.key as keyof typeof t.nav]}
            </a>
          ))}
          <hr class="my-4 border-gray-100" />
          <a
            href="/contact"
            class="w-full flex items-center justify-center gap-2 px-4 py-3.5 bg-gradient-to-br from-aurora-400 to-aurora-500 text-white rounded-xl font-medium shadow-[0_4px_14px_rgba(249,115,22,0.3)]"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            Inquiry
          </a>
        </nav>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-cosmic-500), var(--color-aurora-400));
    border-radius: 1px;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    transform: translateX(-50%);
  }

  .nav-link:hover::after {
    width: calc(100% - 2rem);
  }

  .nav-link:hover {
    color: var(--color-cosmic-600);
  }

  .search-result-item:hover {
    background-color: #f9fafb;
  }
</style>

<script>
  // Product data for search (embedded for client-side search)
  const products = [
    { id: 'tongjing-tj3225k', model: 'TJ3225K-26.000M', frequency: '26MHz', package: 'SMD3225', tolerance: '±10ppm', category: 'resonator' },
    { id: 'tongjing-tj2520k', model: 'TJ2520K-24.000M', frequency: '24MHz', package: 'SMD2520', tolerance: '±20ppm', category: 'resonator' },
    { id: 'tongjing-tj2016k', model: 'TJ2016K-16.000M', frequency: '16MHz', package: 'SMD2016', tolerance: '±10ppm', category: 'resonator' },
    { id: 'tongjing-tj3225o', model: 'TJ3225O-25.000M', frequency: '25MHz', package: 'SMD3225', tolerance: '±50ppm', category: 'oscillator' },
    { id: 'tongjing-tj1610k', model: 'TJ1610K-12.000M', frequency: '12MHz', package: 'SMD1610', tolerance: '±20ppm', category: 'resonator' },
    { id: 'tongjing-tj2520o', model: 'TJ2520O-40.000M', frequency: '40MHz', package: 'SMD2520', tolerance: '±30ppm', category: 'oscillator' },
  ];

  const categories = [
    { key: 'resonators', label: 'Crystal Resonators', href: '/products' },
    { key: 'oscillators', label: 'Crystal Oscillators', href: '/products' },
    { key: 'rtc', label: 'RTC Modules', href: '/products' },
  ];

  function searchProducts(query: string) {
    if (!query || query.length < 2) return [];

    const q = query.toLowerCase().trim();
    const results: Array<{type: string, title: string, subtitle: string, href: string}> = [];

    // Search products
    products.forEach((product) => {
      const model = product.model.toLowerCase();
      const frequency = product.frequency.toLowerCase();
      const pkg = product.package.toLowerCase();
      const cat = product.category.toLowerCase();

      if (model.includes(q) || model.replace(/-/g, '').includes(q.replace(/-/g, '')) ||
          frequency.includes(q) || pkg.toLowerCase().includes(q) || q.includes(frequency) ||
          cat.includes(q)) {
        results.push({
          type: 'product',
          title: product.model,
          subtitle: `${product.frequency} · ${product.package} · ${product.tolerance}`,
          href: `/products/${product.id}`,
        });
      }
    });

    // Search categories
    categories.forEach(cat => {
      if (cat.label.toLowerCase().includes(q) || cat.key.includes(q)) {
        results.push({
          type: 'category',
          title: cat.label,
          subtitle: 'Product Category',
          href: cat.href,
        });
      }
    });

    return results.slice(0, 8);
  }

  function renderSearchResults(results: Array<{type: string, title: string, subtitle: string, href: string}>, query: string) {
    const container = document.getElementById('search-results');
    if (!container) return;

    if (results.length === 0) {
      container.classList.add('hidden');
      return;
    }

    let html = '';
    results.forEach((result) => {
      const icon = result.type === 'product'
        ? '<svg class="w-5 h-5 text-cosmic-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" /></svg>'
        : '<svg class="w-5 h-5 text-aurora-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>';

      html += `
        <a href="${result.href}" class="search-result-item flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors border-b border-gray-100 last:border-0">
          ${icon}
          <div class="flex-1 min-w-0">
            <p class="font-medium text-gray-800 truncate">${result.title}</p>
            <p class="text-sm text-gray-500 truncate">${result.subtitle}</p>
          </div>
          <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      `;
    });

    container.innerHTML = html;
    container.classList.remove('hidden');
  }

  // Desktop search
  const searchInput = document.getElementById('header-search') as HTMLInputElement;
  const searchResults = document.getElementById('search-results');

  let searchTimeout: ReturnType<typeof setTimeout>;
  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value;
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      const results = searchProducts(query);
      renderSearchResults(results, query);
    }, 150);
  });

  searchInput?.addEventListener('blur', () => {
    setTimeout(() => searchResults?.classList.add('hidden'), 200);
  });

  searchInput?.addEventListener('focus', () => {
    if (searchInput.value.length >= 2) {
      searchResults?.classList.remove('hidden');
    }
  });

  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menuClose = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-menu-overlay');

  const openMenu = () => {
    mobileMenu?.classList.remove('hidden');
    menuBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };

  const closeMenu = () => {
    mobileMenu?.classList.add('hidden');
    menuBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  menuBtn?.addEventListener('click', openMenu);
  menuClose?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);
</script>
