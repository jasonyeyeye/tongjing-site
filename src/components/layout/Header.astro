---
import { getLocaleFromUrl, useTranslations } from '../../utils/i18n';
import LanguageSwitcher from '../common/LanguageSwitcher.astro';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const navItems = [
  { key: 'products', href: `/${locale}/products` },
  { key: 'tools', href: `/${locale}/tools` },
  { key: 'news', href: `/${locale}/news` },
  { key: 'about', href: `/${locale}/about` },
  { key: 'contact', href: `/${locale}/contact` },
];
---

<header class="sticky top-0 z-50 bg-white border-b border-light-gray shadow-sm">
  <!-- Desktop Nav -->
  <div class="hidden md:block">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-[72px]">
        <!-- Logo -->
        <a href={`/${locale}`} class="flex items-center gap-2">
          <div class="w-10 h-10 bg-brand-blue rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-lg">TJ</span>
          </div>
          <span class="text-xl font-bold text-brand-blue">TongJing</span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="flex items-center gap-8">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="text-base font-medium text-charcoal hover:text-crystal-orange transition-colors"
            >
              {t.nav[item.key as keyof typeof t.nav] || item.key}
            </a>
          ))}
        </nav>

        <!-- Right Actions -->
        <div class="flex items-center gap-4">
          <LanguageSwitcher locale={locale} />
          <button class="hidden sm:flex items-center gap-2 px-4 py-2 bg-crystal-orange text-white rounded-lg hover:bg-sunset-orange transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <span class="text-sm font-medium">Inquiry</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Search Bar -->
    <div class="border-t border-light-gray">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
        <div class="relative">
          <input
            type="search"
            placeholder="Search products..."
            class="w-full h-10 pl-10 pr-4 rounded-lg border border-light-gray focus:border-tech-blue focus:ring-1 focus:ring-tech-blue transition-colors"
          />
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-mid-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div class="md:hidden">
    <div class="flex justify-between items-center h-16 px-4">
      <a href={`/${locale}`} class="flex items-center gap-2">
        <div class="w-8 h-8 bg-brand-blue rounded-lg flex items-center justify-center">
          <span class="text-white font-bold text-sm">TJ</span>
        </div>
      </a>
      <div class="flex items-center gap-2">
        <LanguageSwitcher locale={locale} />
        <button id="mobile-menu-btn" class="p-2 rounded-lg hover:bg-light-gray transition-colors">
          <svg class="w-6 h-6 text-charcoal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu Drawer -->
    <div id="mobile-menu" class="hidden fixed inset-0 z-50">
      <div class="absolute inset-0 bg-black/50" id="mobile-menu-overlay"></div>
      <div class="absolute right-0 top-0 h-full w-72 bg-white shadow-xl">
        <div class="flex justify-between items-center p-4 border-b border-light-gray">
          <span class="font-bold text-brand-blue">Menu</span>
          <button id="mobile-menu-close" class="p-2 rounded-lg hover:bg-light-gray">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <nav class="p-4 space-y-2">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="block px-4 py-3 rounded-lg text-charcoal hover:bg-light-gray hover:text-crystal-orange transition-colors"
            >
              {t.nav[item.key as keyof typeof t.nav] || item.key}
            </a>
          ))}
          <hr class="my-4 border-light-gray" />
          <button class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-crystal-orange text-white rounded-lg hover:bg-sunset-orange transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            Inquiry
          </button>
        </nav>
      </div>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menuClose = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-menu-overlay');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.remove('hidden');
  });

  const closeMenu = () => {
    mobileMenu?.classList.add('hidden');
  };

  menuClose?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);
</script>
