---
import { getLocaleFromUrl, useTranslations } from '../../utils/i18n';
import LanguageSwitcher from '../common/LanguageSwitcher.astro';
import { brands, type Brand } from '../../data/brands';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

// Get current brand from URL or default to first brand
const currentPath = Astro.url.pathname;
const brandFromUrl = currentPath.split('/')[1];
const currentBrand = brands.find(b => b.slug === brandFromUrl) || brands[0];

const navItems = [
  { key: 'home', href: `/${locale}` },
  { key: 'brands', href: `/${locale}/brands` },
  { key: 'products', href: `/${locale}/${currentBrand.slug}/products` },
  { key: 'tools', href: `/${locale}/tools` },
  { key: 'news', href: `/${locale}/news` },
  { key: 'about', href: `/${locale}/about` },
  { key: 'contact', href: `/${locale}/contact` },
];
---

<header class="sticky top-0 z-50 glass border-b border-gray-200/50">
  <!-- Desktop Nav -->
  <div class="hidden md:block">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-[72px]">
        <!-- Logo with gradient glow -->
        <a href={`/${locale}`} class="flex items-center gap-3 group">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-cosmic-400 to-cosmic-600 rounded-xl blur-lg opacity-40 group-hover:opacity-60 transition-opacity duration-300"></div>
            <div class="relative w-10 h-10 bg-gradient-to-br from-cosmic-500 to-cosmic-700 rounded-xl flex items-center justify-center shadow-lg" style={`background: linear-gradient(135deg, ${currentBrand.primaryColor}, ${currentBrand.primaryColor}dd)`}>
              <span class="text-white font-bold text-lg">{currentBrand.id.slice(0, 2).toUpperCase()}</span>
            </div>
          </div>
          <span class="text-xl font-bold bg-gradient-to-r from-gray-800 to-gray-600 bg-clip-text text-transparent">{currentBrand.name[locale] || currentBrand.name.en}</span>
        </a>

        <!-- Brand Switcher -->
        <div class="relative">
          <button
            id="brand-switch"
            class="flex items-center gap-1 px-3 py-1.5 text-sm text-gray-600 hover:text-cosmic-600 border border-gray-200 rounded-lg hover:border-cosmic-300 transition-colors ml-2"
            aria-expanded="false"
            aria-haspopup="listbox"
          >
            <span class="w-2 h-2 rounded-full" style={`background-color: ${currentBrand.primaryColor}`}></span>
            <span>{currentBrand.name[locale] || currentBrand.name.en}</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <ul
            id="brand-dropdown"
            class="hidden absolute left-0 mt-1 w-40 bg-white border border-gray-200 rounded-lg shadow-lg z-50"
            role="listbox"
          >
            {brands.map((brand) => (
              <li role="option" aria-selected={brand.id === currentBrand.id}>
                <a
                  href={`/${locale}/${brand.slug}/products`}
                  class={`flex items-center gap-2 px-4 py-2 text-sm first:rounded-t-lg last:rounded-b-lg hover:bg-gray-50 ${brand.id === currentBrand.id ? 'text-cosmic-600 font-medium' : 'text-gray-700'}`}
                >
                  <span class="w-2 h-2 rounded-full" style={`background-color: ${brand.primaryColor}`}></span>
                  <span>{brand.name[locale] || brand.name.en}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Desktop Navigation with underline animation -->
        <nav class="flex items-center gap-1" aria-label="Main navigation">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="nav-link relative px-4 py-2 text-base font-medium text-gray-600 hover:text-cosmic-600 transition-colors duration-200"
            >
              {t.nav[item.key as keyof typeof t.nav] || item.key}
            </a>
          ))}
        </nav>

        <!-- Right Actions -->
        <div class="flex items-center gap-3">
          <LanguageSwitcher locale={locale} />
          <a
            href={`/${locale}/contact`}
            class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-br from-aurora-400 to-aurora-500 text-white rounded-xl font-medium text-sm shadow-[0_4px_14px_rgba(249,115,22,0.3)] hover:shadow-[0_6px_20px_rgba(249,115,22,0.4)] hover:from-aurora-300 hover:to-aurora-400 transition-all duration-200 active:scale-[0.97]"
            aria-label="Send inquiry"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <span>{t.nav.contact || 'Inquiry'}</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Search Bar -->
    <div class="border-t border-gray-200/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
        <div class="relative">
          <input
            type="search"
            placeholder={t.product.search || 'Search products...'}
            aria-label={t.product.search || 'Search products'}
            class="w-full h-11 pl-11 pr-4 rounded-xl border border-gray-200 bg-white/80 text-gray-800 placeholder:text-gray-400 focus:border-cosmic-400 focus:ring-4 focus:ring-cosmic-400/10 hover:border-gray-300 transition-all duration-200"
          />
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div class="md:hidden">
    <div class="flex justify-between items-center h-16 px-4">
      <a href={`/${locale}`} class="flex items-center gap-2">
        <div class="w-9 h-9 bg-gradient-to-br from-cosmic-500 to-cosmic-700 rounded-lg flex items-center justify-center shadow-md" style={`background: linear-gradient(135deg, ${currentBrand.primaryColor}, ${currentBrand.primaryColor}dd)`}>
          <span class="text-white font-bold text-sm">{currentBrand.id.slice(0, 2).toUpperCase()}</span>
        </div>
      </a>
      <div class="flex items-center gap-2">
        <LanguageSwitcher locale={locale} />
        <button
          id="mobile-menu-btn"
          class="p-2 rounded-lg hover:bg-gray-100 transition-colors"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Open menu"
        >
          <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu Drawer -->
    <div id="mobile-menu" class="hidden fixed inset-0 z-50" role="dialog" aria-modal="true" aria-labelledby="mobile-menu-title">
      <div class="absolute inset-0 bg-gray-900/50 backdrop-blur-sm" id="mobile-menu-overlay"></div>
      <div class="absolute right-0 top-0 h-full w-80 max-w-[85vw] bg-white shadow-2xl">
        <div class="flex justify-between items-center p-4 border-b border-gray-100">
          <span id="mobile-menu-title" class="font-bold text-lg bg-gradient-to-r from-cosmic-600 to-cosmic-500 bg-clip-text text-transparent">Menu</span>
          <button id="mobile-menu-close" class="p-2 rounded-lg hover:bg-gray-100 transition-colors" aria-label="Close menu">
            <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <nav class="p-4 space-y-1" aria-label="Mobile navigation">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="block px-4 py-3 rounded-xl text-gray-700 hover:bg-gray-50 hover:text-cosmic-600 transition-colors font-medium"
            >
              {t.nav[item.key as keyof typeof t.nav] || item.key}
            </a>
          ))}
          <hr class="my-4 border-gray-100" />
          <a
            href={`/${locale}/contact`}
            class="w-full flex items-center justify-center gap-2 px-4 py-3.5 bg-gradient-to-br from-aurora-400 to-aurora-500 text-white rounded-xl font-medium shadow-[0_4px_14px_rgba(249,115,22,0.3)]"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            {t.nav.contact || 'Inquiry'}
          </a>
        </nav>
      </div>
    </div>
  </div>
</header>

<style>
  /* Navigation underline animation */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-cosmic-500), var(--color-aurora-400));
    border-radius: 1px;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    transform: translateX(-50%);
  }

  .nav-link:hover::after {
    width: calc(100% - 2rem);
  }

  .nav-link:hover {
    color: var(--color-cosmic-600);
  }
</style>

<script>
  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menuClose = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-menu-overlay');

  const openMenu = () => {
    mobileMenu?.classList.remove('hidden');
    menuBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };

  const closeMenu = () => {
    mobileMenu?.classList.add('hidden');
    menuBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  menuBtn?.addEventListener('click', openMenu);
  menuClose?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);

  // Brand dropdown
  const brandBtn = document.getElementById('brand-switch');
  const brandDropdown = document.getElementById('brand-dropdown');

  brandBtn?.addEventListener('click', () => {
    const isHidden = brandDropdown?.classList.contains('hidden');
    brandDropdown?.classList.toggle('hidden');
    brandBtn?.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
  });

  document.addEventListener('click', (e) => {
    if (!brandBtn?.contains(e.target as Node) && !brandDropdown?.contains(e.target as Node)) {
      brandDropdown?.classList.add('hidden');
      brandBtn?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
