---
interface Props {
  label?: string;
  name: string;
  options: Array<{ value: string; label: string }>;
  required?: boolean;
  class?: string;
}

const { label, name, options, required = false, class: className = '' } = Astro.props;
---

<div class="space-y-1">
  {label && (
    <label for={name} class="block text-sm font-medium text-charcoal">
      {label}
      {required && <span class="text-error"> *</span>}
    </label>
  )}
  <select
    name={name}
    id={name}
    required={required}
    class={`w-full h-12 px-4 rounded-lg border border-light-gray text-charcoal bg-white focus:border-tech-blue focus:ring-1 focus:ring-tech-blue transition-colors ${className}`}
  >
    {options.map((opt) => (
      <option value={opt.value}>{opt.label}</option>
    ))}
  </select>
</div>
