---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  class?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  disabled = false,
  class: className = '',
} = Astro.props;

// New design with gradients, glows, and micro-interactions
const baseStyles = 'inline-flex items-center justify-center font-medium rounded-xl transition-all duration-200 ease-out-expo focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 active:scale-[0.97]';

const variants = {
  primary: `
    bg-gradient-to-br from-aurora-400 to-aurora-500
    text-white
    hover:from-aurora-300 hover:to-aurora-400
    hover:shadow-[0_4px_14px_rgba(249,115,22,0.35)]
    focus-visible:ring-aurora-400
    disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:shadow-none
  `,
  secondary: `
    bg-gradient-to-br from-cosmic-600 to-cosmic-700
    text-white
    hover:from-cosmic-500 hover:to-cosmic-600
    hover:shadow-[0_4px_14px_rgba(37,99,235,0.25)]
    focus-visible:ring-cosmic-500
    disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:shadow-none
  `,
  outline: `
    border-2 border-cosmic-500 text-cosmic-600
    hover:bg-gradient-to-br hover:from-cosmic-500 hover:to-cosmic-600 hover:text-white hover:border-cosmic-500
    focus-visible:ring-cosmic-500
    disabled:opacity-50 disabled:cursor-not-allowed
  `,
  ghost: `
    text-cosmic-600
    hover:bg-cosmic-100 hover:text-cosmic-700
    focus-visible:ring-cosmic-500
  `,
};

const sizes = {
  sm: 'px-3 py-1.5 text-sm gap-1.5',
  md: 'px-4 py-2.5 text-base gap-2',
  lg: 'px-6 py-3 text-lg gap-2.5',
};

const classes = `${baseStyles} ${variants[variant]} ${sizes[size]} ${className}`;

const Tag = href ? 'a' : 'button';
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} disabled={disabled} class={classes}>
    <slot />
  </button>
)}

<style>
  /* Smooth transition for gradient buttons */
  [class*="bg-gradient"] {
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
