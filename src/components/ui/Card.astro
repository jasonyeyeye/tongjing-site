---
interface Props {
  class?: string;
  hover?: boolean;
  glass?: boolean;
}

const { class: className = '', hover = false, glass = false } = Astro.props;

const baseClasses = glass
  ? 'bg-white/80 backdrop-blur-xl border border-gray-200/50'
  : 'bg-white border border-gray-200';

const hoverClasses = hover
  ? `
    hover:border-cosmic-300
    hover:shadow-[0_4px_6px_rgba(37,99,235,0.04),0_10px_20px_rgba(0,0,0,0.06),0_0_0_1px_rgba(37,99,235,0.08)]
    hover:-translate-y-1
    transition-all duration-300 ease-out-expo
    cursor-pointer
  `
  : 'shadow-sm';

const classes = `${baseClasses} ${hoverClasses} rounded-2xl ${className}`;
---

<div class={classes}>
  <slot />
</div>
