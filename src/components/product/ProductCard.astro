---
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
import { getLocaleFromUrl, useTranslations } from '../../utils/i18n';

interface Props {
  model: string;
  brand?: string;
  image?: string;
  frequency: string;
  tolerance: string;
  packageType: string;
  loadCapacitance?: string;
  esr?: string;
  stock?: string;
  priceRange?: string;
  badge?: 'hot' | 'new' | 'default' | 'discontinued' | 'futures';
  href: string;
}

const {
  model,
  brand = 'TongJing',
  image,
  frequency,
  tolerance,
  packageType,
  loadCapacitance,
  esr,
  stock,
  priceRange,
  badge = 'default',
  href,
} = Astro.props;

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const badgeLabels: Record<string, string> = {
  hot: locale === 'zh' ? '热销' : locale === 'ja' ? '热销' : locale === 'de' ? 'Heiß' : 'Hot',
  new: locale === 'zh' ? '新品' : locale === 'ja' ? '新型' : locale === 'de' ? 'Neu' : 'New',
  default: locale === 'zh' ? '常规' : locale === 'ja' ? '通常' : locale === 'de' ? 'Standard' : 'Standard',
  discontinued: locale === 'zh' ? '停产' : locale === 'ja' ? '生産中止' : locale === 'de' ? 'Eingestellt' : 'Discontinued',
  futures: locale === 'zh' ? '期货' : locale === 'ja' ? '先物' : locale === 'de' ? 'Zukunft' : 'Future',
};

const labels = {
  freq: locale === 'zh' ? '频率' : locale === 'ja' ? '周波数' : locale === 'de' ? 'Frequenz' : 'Freq',
  tolerance: locale === 'zh' ? '精度' : locale === 'ja' ? '許容差' : locale === 'de' ? 'Toleranz' : 'Tolerance',
  package: locale === 'zh' ? '封装' : locale === 'ja' ? 'パッケージ' : locale === 'de' ? 'Gehäuse' : 'Package',
  load: locale === 'zh' ? '负载电容' : locale === 'ja' ? '負荷容量' : locale === 'de' ? 'Last' : 'Load',
  esr: locale === 'zh' ? '等效串联电阻' : locale === 'ja' ? '等価直列抵抗' : locale === 'de' ? 'ESR' : 'ESR',
  stock: locale === 'zh' ? '库存' : locale === 'ja' ? '在庫' : locale === 'de' ? 'Bestand' : 'Stock',
  datasheet: locale === 'zh' ? '数据手册' : locale === 'ja' ? 'データシート' : locale === 'de' ? 'Datenblatt' : 'Datasheet',
  details: locale === 'zh' ? '详情' : locale === 'ja' ? '詳細' : locale === 'de' ? 'Details' : 'Details',
  inquiry: locale === 'zh' ? '询价' : locale === 'ja' ? 'Inquiry' : locale === 'de' ? 'Anfrage' : 'Inquiry',
};
---

<div class="group relative bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300 ease-out-expo overflow-hidden">
  <!-- Glow effect on hover -->
  <div class="absolute -inset-1 bg-gradient-to-br from-cosmic-400/20 to-aurora-400/20 rounded-2xl opacity-0 group-hover:opacity-100 blur-xl transition-opacity duration-300 -z-10"></div>

  <!-- Image -->
  <div class="aspect-square bg-gradient-to-br from-gray-50 to-gray-100 relative overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={`${model} product image`}
        class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-500 ease-out"
        loading="lazy"
        width="300"
        height="300"
      />
    ) : (
      <div class="flex items-center justify-center h-full bg-gradient-to-br from-gray-100 to-gray-50" role="img" aria-label="Product image placeholder">
        <div class="w-20 h-20 rounded-2xl bg-white/80 shadow-md flex items-center justify-center">
          <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      </div>
    )}

    <!-- Gradient overlay on hover -->
    <div class="absolute inset-0 bg-gradient-to-t from-cosmic-600/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

    <!-- Badge -->
    <div class="absolute top-3 left-3">
      <Badge variant={badge} pulse={badge === 'hot'}>{badgeLabels[badge]}</Badge>
    </div>
  </div>

  <!-- Content -->
  <div class="p-5">
    <!-- Model & Brand -->
    <div class="flex items-start justify-between gap-2 mb-4">
      <h3 class="font-mono text-base font-semibold text-gray-800 group-hover:text-cosmic-600 transition-colors duration-200">
        {model}
      </h3>
      <span class="text-xs text-gray-400 shrink-0 bg-gray-100 px-2 py-1 rounded-md">{brand}</span>
    </div>

    <!-- Core Parameters -->
    <dl class="space-y-1.5 text-sm mb-5">
      <div class="flex items-center gap-3 p-2 rounded-lg bg-gray-50/80">
        <dt class="text-gray-400 text-xs w-16">{labels.freq}</dt>
        <dd class="text-gray-700 font-medium">{frequency}</dd>
      </div>
      <div class="flex items-center gap-3 p-2 rounded-lg bg-gray-50/80">
        <dt class="text-gray-400 text-xs w-16">{labels.tolerance}</dt>
        <dd class="text-gray-700 font-medium">{tolerance}</dd>
      </div>
      <div class="flex items-center gap-3 p-2 rounded-lg bg-gray-50/80">
        <dt class="text-gray-400 text-xs w-16">{labels.package}</dt>
        <dd class="text-gray-700 font-medium">{packageType}</dd>
      </div>
      {loadCapacitance && (
        <div class="flex items-center gap-3 p-2 rounded-lg bg-gray-50/80">
          <dt class="text-gray-400 text-xs w-16">{labels.load}</dt>
          <dd class="text-gray-700 font-medium">{loadCapacitance}</dd>
        </div>
      )}
      {esr && (
        <div class="flex items-center gap-3 p-2 rounded-lg bg-gray-50/80">
          <dt class="text-gray-400 text-xs w-16">{labels.esr}</dt>
          <dd class="text-gray-700 font-medium">{esr}</dd>
        </div>
      )}
    </dl>

    <!-- Stock & Price -->
    {stock && (
      <div class="bg-gradient-to-r from-success/5 to-success/10 border border-success/20 rounded-xl p-3 mb-5">
        <div class="flex items-center justify-between text-sm">
          <span class="flex items-center gap-2 text-success">
            <span class="w-2 h-2 bg-success rounded-full animate-pulse"></span>
            {labels.stock}: {stock}
          </span>
        </div>
        {priceRange && (
          <p class="text-aurora-500 font-bold mt-1">{priceRange}</p>
        )}
      </div>
    )}

    <!-- Actions -->
    <div class="flex items-center justify-between gap-1">
      <button class="flex-1 flex items-center justify-center gap-1 px-2 py-2 rounded-lg border border-gray-200 text-gray-600 hover:border-cosmic-300 hover:text-cosmic-600 hover:bg-cosmic-50 transition-all duration-200 text-xs font-medium">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        {labels.datasheet}
      </button>
      <a
        href={href}
        class="px-3 py-2 rounded-lg text-cosmic-600 hover:bg-cosmic-50 transition-all duration-200 text-xs font-medium text-center"
      >
        {labels.details}
      </a>
      <a
        href={`${href}?inquiry=true`}
        class="px-3 py-2 rounded-lg bg-gradient-to-br from-aurora-400 to-aurora-500 text-white font-medium text-xs text-center shadow-[0_2px_8px_rgba(249,115,22,0.25)] hover:shadow-[0_4px_12px_rgba(249,115,22,0.35)] hover:from-aurora-300 hover:to-aurora-400 transition-all duration-200"
      >
        {labels.inquiry}
      </a>
    </div>
  </div>
</div>
