---
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';

interface Props {
  model: string;
  brand?: string;
  image?: string;
  frequency: string;
  tolerance: string;
  package: string;
  loadCapacitance?: string;
  esr?: string;
  stock?: string;
  priceRange?: string;
  badge?: 'hot' | 'new' | 'default' | 'discontinued' | 'futures';
  href: string;
}

const {
  model,
  brand = 'TongJing',
  image,
  frequency,
  tolerance,
  package: pkg,
  loadCapacitance,
  esr,
  stock,
  priceRange,
  badge = 'default',
  href,
} = Astro.props;

const badgeLabels = {
  hot: '热销',
  new: '新品',
  default: '常规',
  discontinued: '停产',
  futures: '期货',
};
---

<div class="group bg-white rounded-xl border border-light-gray shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden">
  <!-- Image -->
  <div class="aspect-square bg-light-gray relative overflow-hidden">
    {image ? (
      <img src={image} alt={model} class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-300" />
    ) : (
      <div class="flex items-center justify-center h-full">
        <svg class="w-16 h-16 text-mid-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}
    <!-- Badge -->
    <div class="absolute top-3 left-3">
      <Badge variant={badge}>{badgeLabels[badge]}</Badge>
    </div>
  </div>

  <!-- Content -->
  <div class="p-5">
    <!-- Model & Brand -->
    <div class="flex items-start justify-between gap-2 mb-3">
      <h3 class="font-mono text-base font-semibold text-charcoal group-hover:text-crystal-orange transition-colors">
        {model}
      </h3>
      <span class="text-xs text-mid-gray shrink-0">{brand}</span>
    </div>

    <!-- Core Parameters -->
    <div class="space-y-1 text-sm mb-4">
      <p class="text-dark-gray">
        <span class="text-mid-gray">频率:</span> {frequency}
      </p>
      <p class="text-dark-gray">
        <span class="text-mid-gray">精度:</span> {tolerance}
      </p>
      <p class="text-dark-gray">
        <span class="text-mid-gray">封装:</span> {pkg}
      </p>
      {loadCapacitance && (
        <p class="text-dark-gray">
          <span class="text-mid-gray">负载:</span> {loadCapacitance}
        </p>
      )}
      {esr && (
        <p class="text-dark-gray">
          <span class="text-mid-gray">ESR:</span> {esr}
        </p>
      )}
    </div>

    <!-- Stock & Price -->
    {stock && (
      <div class="bg-light-gray rounded-lg p-3 mb-4">
        <div class="flex items-center justify-between text-sm">
          <span class="flex items-center gap-1.5 text-success">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            库存: {stock}
          </span>
        </div>
        {priceRange && (
          <p class="text-crystal-orange font-semibold mt-1">{priceRange}</p>
        )}
      </div>
    )}

    <!-- Actions -->
    <div class="flex items-center gap-2">
      <Button variant="outline" size="sm" class="flex-1">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Datasheet
      </Button>
      <Button variant="ghost" size="sm" href={href}>
        详情
      </Button>
      <Button variant="primary" size="sm">
        询价
      </Button>
    </div>
  </div>
</div>
