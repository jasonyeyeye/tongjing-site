---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/layout/Container.astro';
import ProductCard from '../../../components/product/ProductCard.astro';
import FilterSidebar from '../../../components/product/FilterSidebar.astro';
import Button from '../../../components/ui/Button.astro';
import { useTranslations } from '../../../utils/i18n';

const t = useTranslations('de');

const filters = [
  {
    name: '产品类型',
    options: [
      { value: 'resonators', label: '谐振器', count: 86 },
      { value: 'oscillators', label: '振荡器', count: 42 },
      { value: 'rtc', label: 'RTC模块', count: 24 },
    ],
  },
  {
    name: '封装规格',
    options: [
      { value: '3225', label: '3225', count: 45 },
      { value: '2520', label: '2520', count: 38 },
      { value: '2016', label: '2016', count: 29 },
      { value: '1610', label: '1610', count: 12 },
    ],
  },
  {
    name: '频率范围',
    options: [
      { value: '8-16mhz', label: '8-16MHz', count: 32 },
      { value: '16-25mhz', label: '16-25MHz', count: 48 },
      { value: '25-50mhz', label: '25-50MHz', count: 55 },
      { value: '50-100mhz', label: '50-100MHz', count: 17 },
    ],
  },
  {
    name: '频率偏差',
    options: [
      { value: '±10ppm', label: '±10ppm', count: 52 },
      { value: '±20ppm', label: '±20ppm', count: 41 },
      { value: '±30ppm', label: '±30ppm', count: 38 },
      { value: '±50ppm', label: '±50ppm', count: 21 },
    ],
  },
];

const products = [
  { model: 'TJ3225K-26.000M', frequency: '26MHz', tolerance: '±10ppm', package: 'SMD3225', stock: '500,000 PCS', priceRange: '$0.08 - $0.12', badge: 'hot' as const, href: '/zh/products/tj3225k' },
  { model: 'TJ2520K-24.000M', frequency: '24MHz', tolerance: '±20ppm', package: 'SMD2520', stock: '320,000 PCS', priceRange: '$0.07 - $0.10', badge: 'new' as const, href: '/zh/products/tj2520k' },
  { model: 'TJ2016K-16.000M', frequency: '16MHz', tolerance: '±10ppm', package: 'SMD2016', stock: '180,000 PCS', priceRange: '$0.06 - $0.09', badge: 'default' as const, href: '/zh/products/tj2016k' },
  { model: 'TJ3225O-25.000M', frequency: '25MHz', tolerance: '±50ppm', package: 'SMD3225', stock: '期货 2周', badge: 'futures' as const, href: '/zh/products/tj3225o' },
  { model: 'TJ1610K-12.000M', frequency: '12MHz', tolerance: '±20ppm', package: 'SMD1610', stock: '85,000 PCS', priceRange: '$0.05 - $0.07', badge: 'default' as const, href: '/zh/products/tj1610k' },
  { model: 'TJ2520O-40.000M', frequency: '40MHz', tolerance: '±30ppm', package: 'SMD2520', stock: '150,000 PCS', priceRange: '$0.09 - $0.13', badge: 'default' as const, href: '/zh/products/tj2520o' },
];
---

<BaseLayout title={`${t.product.title} - ${t.seo.title}`} description={t.seo.description}>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-brand-blue to-deep-navy text-white py-12">
    <Container>
      <h1 class="text-3xl font-bold mb-2">{t.product.title}</h1>
      <p class="text-white/80">共 152 个产品</p>
    </Container>
  </section>

  <Container class="py-12">
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Filters Sidebar -->
      <aside class="lg:w-64 shrink-0">
        <div class="sticky top-24 bg-white rounded-xl border border-light-gray p-6">
          <h3 class="font-semibold text-charcoal mb-4">筛选条件</h3>
          <FilterSidebar filters={filters} />
        </div>
      </aside>

      <!-- Products Grid -->
      <div class="flex-1">
        <!-- Sort & View Controls -->
        <div class="flex items-center justify-between mb-6">
          <p class="text-sm text-mid-gray">找到 152 个产品</p>
          <div class="flex items-center gap-4">
            <select class="text-sm border border-light-gray rounded-lg px-3 py-2">
              <option>默认排序</option>
              <option>销量优先</option>
              <option>最新上架</option>
              <option>价格从低到高</option>
            </select>
          </div>
        </div>

        <!-- Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
          {products.map((product) => (
            <ProductCard
              model={product.model}
              frequency={product.frequency}
              tolerance={product.tolerance}
              package={product.package}
              stock={product.stock}
              priceRange={product.priceRange}
              badge={product.badge}
              href={product.href}
            />
          ))}
        </div>

        <!-- Pagination -->
        <div class="flex justify-center gap-2 mt-12">
          <Button variant="outline" size="sm" disabled>上一页</Button>
          <Button variant="primary" size="sm">1</Button>
          <Button variant="outline" size="sm">2</Button>
          <Button variant="outline" size="sm">3</Button>
          <span class="px-2 py-2 text-mid-gray">...</span>
          <Button variant="outline" size="sm">8</Button>
          <Button variant="outline" size="sm">下一页</Button>
        </div>
      </div>
    </div>
  </Container>

  <!-- CTA -->
  <section class="py-12 bg-light-gray">
    <Container class="text-center">
      <p class="text-mid-gray mb-4">需要帮助？联系我们的技术专家</p>
      <Button variant="primary" href={`/${'zh'}/contact`}>联系我们</Button>
    </Container>
  </section>
</BaseLayout>
