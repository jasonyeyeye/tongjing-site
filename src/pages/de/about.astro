---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import Button from '../../components/ui/Button.astro';
import { useTranslations } from '../../utils/i18n';

const t = useTranslations('de');

const timeline = [
  { year: '2005', event: '公司成立，开始从事晶体谐振器研发' },
  { year: '2010', event: '第一条自动化产线投产，月产能突破1000万只' },
  { year: '2015', event: '通过 ISO9001、ISO14001 认证' },
  { year: '2018', event: '推出SMD2016、SMD1610小尺寸产品线' },
  { year: '2020', event: 'RTC模块产品量产，进入汽车电子市场' },
  { year: '2023', event: '通过 AEC-Q100 认证，产能突破1亿只/月' },
];

const certifications = ['ISO9001', 'ISO14001', 'RoHS', 'REACH', 'AEC-Q100', '无卤'];
---

<BaseLayout title={`${t.about.title} - ${t.seo.title}`} description={t.seo.description}>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-brand-blue to-deep-navy text-white py-20">
    <Container>
      <h1 class="text-4xl font-bold mb-4">{t.about.title}</h1>
      <p class="text-xl text-white/80">{t.about.subtitle}</p>
    </Container>
  </section>

  <!-- Intro -->
  <section class="py-16">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-2xl font-bold text-charcoal mb-6">公司简介</h2>
          <p class="text-dark-gray leading-relaxed mb-6">
            {t.about.intro}
          </p>
          <p class="text-dark-gray leading-relaxed mb-6">
            公司拥有自主研发中心，配备先进的生产和检测设备，产品广泛应用于通信设备、消费电子、汽车电子、工业控制、医疗设备等领域。产品远销日本、韩国、欧美等国际市场。
          </p>
        </div>
        <div class="bg-light-gray rounded-xl aspect-video flex items-center justify-center">
          <svg class="w-24 h-24 text-mid-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
      </div>
    </Container>
  </section>

  <!-- Strengths -->
  <section class="py-16 bg-light-gray">
    <Container>
      <h2 class="text-3xl font-bold text-center text-charcoal mb-12">核心优势</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white rounded-xl p-6 text-center">
          <div class="text-5xl mb-4">🏭</div>
          <h3 class="text-lg font-semibold text-charcoal mb-2">{t.about.strengths.automation.title}</h3>
          <p class="text-sm text-mid-gray">{t.about.strengths.automation.desc}</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center">
          <div class="text-5xl mb-4">⚡</div>
          <h3 class="text-lg font-semibold text-charcoal mb-2">{t.about.strengths.quality.title}</h3>
          <p class="text-sm text-mid-gray">{t.about.strengths.quality.desc}</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center">
          <div class="text-5xl mb-4">🎯</div>
          <h3 class="text-lg font-semibold text-charcoal mb-2">{t.about.strengths.direct.title}</h3>
          <p class="text-sm text-mid-gray">{t.about.strengths.direct.desc}</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center">
          <div class="text-5xl mb-4">🔬</div>
          <h3 class="text-lg font-semibold text-charcoal mb-2">{t.about.strengths.capacity.title}</h3>
          <p class="text-sm text-mid-gray">{t.about.strengths.capacity.desc}</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Timeline -->
  <section class="py-16">
    <Container>
      <h2 class="text-3xl font-bold text-center text-charcoal mb-12">发展历程</h2>
      <div class="max-w-4xl mx-auto">
        {timeline.map((item, index) => (
          <div class="flex gap-4 mb-8">
            <div class="shrink-0 w-20 text-right">
              <span class="text-lg font-bold text-crystal-orange">{item.year}</span>
            </div>
            <div class="relative pl-8 border-l-2 border-light-gray">
              <div class="absolute left-0 top-1 w-3 h-3 bg-crystal-orange rounded-full -translate-x-[7px]"></div>
              <p class="text-dark-gray">{item.event}</p>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Certifications -->
  <section class="py-16 bg-brand-blue text-white">
    <Container>
      <h2 class="text-3xl font-bold text-center mb-8">{t.about.certifications.title}</h2>
      <div class="flex flex-wrap justify-center gap-4">
        {certifications.map((cert) => (
          <span class="px-6 py-3 bg-white/10 rounded-lg font-medium">{cert}</span>
        ))}
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <Container class="text-center">
      <h2 class="text-2xl font-bold text-charcoal mb-4">了解更多</h2>
      <p class="text-mid-gray mb-6">欢迎联系我们，了解更多产品信息</p>
      <div class="flex justify-center gap-4">
        <Button variant="primary" href={`/${'zh'}/products`}>{t.nav.products}</Button>
        <Button variant="outline" href={`/${'zh'}/contact`}>{t.nav.contact}</Button>
      </div>
    </Container>
  </section>
</BaseLayout>
