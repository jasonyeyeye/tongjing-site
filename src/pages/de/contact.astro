---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import ContactForm from '../../components/form/ContactForm.astro';
import { useTranslations } from '../../utils/i18n';

const t = useTranslations('de');
---

<BaseLayout title={`${t.contact.title} - ${t.seo.title}`} description={t.seo.description}>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-brand-blue to-deep-navy text-white py-16">
    <Container>
      <h1 class="text-3xl font-bold mb-2">{t.contact.title}</h1>
      <p class="text-white/80">{t.contact.subtitle}</p>
    </Container>
  </section>

  <!-- Contact Info & Form -->
  <section class="py-16">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Contact Info -->
        <div class="lg:col-span-1 space-y-8">
          <div>
            <h3 class="text-lg font-semibold text-charcoal mb-4">联系方式</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-crystal-orange mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <div>
                  <p class="text-sm text-mid-gray">{t.contact.phone}</p>
                  <p class="text-charcoal font-medium">0551-XXXX-XXXX</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-crystal-orange mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <div>
                  <p class="text-sm text-mid-gray">{t.contact.email}</p>
                  <p class="text-charcoal font-medium">info@tongjing.com</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-crystal-orange mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <p class="text-sm text-mid-gray">{t.contact.address}</p>
                  <p class="text-charcoal font-medium">合肥市高新技术产业开发区</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-crystal-orange mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <p class="text-sm text-mid-gray">{t.contact.hours}</p>
                  <p class="text-charcoal font-medium">周一至周五 9:00 - 18:00</p>
                </div>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-lg font-semibold text-charcoal mb-4">{t.contact.offices.title}</h3>
            <div class="space-y-3">
              <div class="bg-light-gray rounded-lg p-4">
                <p class="font-medium text-charcoal">{t.contact.offices.shenzhen}</p>
                <p class="text-sm text-mid-gray">深圳市南山区科技园</p>
              </div>
              <div class="bg-light-gray rounded-lg p-4">
                <p class="font-medium text-charcoal">{t.contact.offices.jiangsu}</p>
                <p class="text-sm text-mid-gray">苏州市工业园区</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <ContactForm />
        </div>
      </div>
    </Container>
  </section>

  <!-- Map Placeholder -->
  <section class="py-8">
    <Container>
      <div class="bg-light-gray rounded-xl aspect-video flex items-center justify-center">
        <div class="text-center">
          <svg class="w-16 h-16 text-mid-gray mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <p class="text-mid-gray">地图位置</p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
