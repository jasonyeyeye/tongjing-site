---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ProductCard from '../../components/ProductCard.astro';
import { useTranslations } from '../../utils/i18n';

const t = useTranslations('en');
---

<BaseLayout title={t.seo.title} description={t.seo.description}>
  <Hero locale="en" />
  
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">{t.product.title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <ProductCard
          title={t.product.resonators}
          description="HC-49S/SMD crystal resonators, frequency range 3.2MHz~100MHz"
          href="/en/products/resonators"
        />
        <ProductCard
          title={t.product.oscillators}
          description="Crystal oscillators with precision up to ±10ppm"
          href="/en/products/oscillators"
        />
        <ProductCard
          title={t.product.rtc}
          description="RTC modules with integrated crystal and compensation circuit"
          href="/en/products/rtc"
        />
      </div>
    </div>
  </section>
</BaseLayout>
