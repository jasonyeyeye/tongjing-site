---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/layout/Container.astro';
import ContactForm from '../components/form/ContactForm.astro';
import { useTranslations } from '../utils/i18n';

const t = useTranslations();
---

<BaseLayout
  title="Contact China NewChip - Get Quote & Technical Support"
  description="Contact China NewChip for product inquiries, technical support, and custom solutions. Our team serves global buyers with expertise in Chinese electronic components and semiconductor products."
  pageType="contact"
>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-cosmic-600 to-cosmic-800 text-white py-16">
    <Container>
      <h1 class="text-3xl font-bold mb-2">{t.contact.title}</h1>
      <p class="text-white/80">{t.contact.subtitle}</p>
    </Container>
  </section>

  <!-- Contact Info & Form -->
  <section class="py-16">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Contact Info -->
        <div class="lg:col-span-1 space-y-8">
          <div>
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Contact Information</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-aurora-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <div>
                  <p class="text-sm text-gray-500">{t.contact.phone}</p>
                  <p class="text-gray-800 font-medium">0551-XXXX-XXXX</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-aurora-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <div>
                  <p class="text-sm text-gray-500">{t.contact.email}</p>
                  <p class="text-gray-800 font-medium">info@tongjing.com</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-aurora-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <p class="text-sm text-gray-500">{t.contact.address}</p>
                  <p class="text-gray-800 font-medium">Hefei High-tech Industrial Development Zone</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-aurora-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <p class="text-sm text-gray-500">{t.contact.hours}</p>
                  <p class="text-gray-800 font-medium">Monday to Friday 9:00 - 18:00</p>
                </div>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-lg font-semibold text-gray-800 mb-4">{t.contact.offices.title}</h3>
            <div class="space-y-3">
              <div class="bg-gray-50 rounded-lg p-4">
                <p class="font-medium text-gray-800">{t.contact.offices.shenzhen}</p>
                <p class="text-sm text-gray-500">Shenzhen Nanshan Science Park</p>
              </div>
              <div class="bg-gray-50 rounded-lg p-4">
                <p class="font-medium text-gray-800">{t.contact.offices.jiangsu}</p>
                <p class="text-sm text-gray-500">Suzhou Industrial Park</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <ContactForm />
        </div>
      </div>
    </Container>
  </section>

  <!-- Map Placeholder -->
  <section class="py-8">
    <Container>
      <div class="bg-gray-100 rounded-xl aspect-video flex items-center justify-center">
        <div class="text-center">
          <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <p class="text-gray-500">Map Location</p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
