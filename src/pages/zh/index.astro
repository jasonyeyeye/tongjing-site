---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ProductCard from '../../components/ProductCard.astro';
import { useTranslations } from '../../utils/i18n';

const t = useTranslations('zh');
---

<BaseLayout title={t.seo.title} description={t.seo.description}>
  <Hero locale="zh" />
  
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">{t.product.title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <ProductCard
          title={t.product.resonators}
          description="HC-49S/SMD 贴片谐振器，频率范围 3.2MHz~100MHz"
          href="/zh/products/resonators"
        />
        <ProductCard
          title={t.product.oscillators}
          description="石英晶体振荡器，精度可达 ±10ppm"
          href="/zh/products/oscillators"
        />
        <ProductCard
          title={t.product.rtc}
          description="实时时钟模块，集成晶体和补偿电路"
          href="/zh/products/rtc"
        />
      </div>
    </div>
  </section>
</BaseLayout>
