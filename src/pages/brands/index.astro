---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import { brands } from '../../data/brands';
import { useTranslations } from '../../utils/i18n';

const t = useTranslations();
---

<BaseLayout
  title="Chinese Electronics Brands - Semiconductor & Component Manufacturers | China NewChip"
  description="Explore certified Chinese electronics brands and semiconductor manufacturers. Quality crystal resonators, oscillators, and electronic components from trusted factories in China."
  pageType="brands"
>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-cosmic-600 to-cosmic-800 text-white py-16">
    <Container>
      <h1 class="text-4xl font-bold mb-4">Chinese Electronics Brands Platform</h1>
      <p class="text-white/80 text-lg">
        Discover premium electronic component manufacturers from China — certified quality, competitive pricing, and reliable global delivery
      </p>
    </Container>
  </section>

  <!-- Brands Grid -->
  <Container class="py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {brands.map((brand) => (
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow duration-300">
          <!-- Brand Header -->
          <div
            class="h-32 relative flex items-center justify-center"
            style={`background: linear-gradient(135deg, ${brand.primaryColor}15, ${brand.primaryColor}30)`}
          >
            <div
              class="w-20 h-20 rounded-2xl flex items-center justify-center shadow-lg"
              style={`background: linear-gradient(135deg, ${brand.primaryColor}, ${brand.primaryColor}cc)`}
            >
              <span class="text-white font-bold text-2xl">{brand.id.slice(0, 2).toUpperCase()}</span>
            </div>
            <span class="absolute top-4 right-4 px-3 py-1 bg-green-500 text-white text-xs font-medium rounded-full">
              Active
            </span>
          </div>

          <!-- Brand Info -->
          <div class="p-6">
            <h2 class="text-2xl font-bold text-gray-900 mb-2">
              {brand.name.en}
            </h2>
            <p class="text-cosmic-600 font-medium mb-3">
              {brand.tagline.en}
            </p>
            <p class="text-gray-600 text-sm mb-6 line-clamp-3">
              {brand.description.en}
            </p>

            <!-- Brand Actions -->
            <div class="flex gap-3">
              <a
                href="/products"
                class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-cosmic-600 text-white rounded-xl font-medium text-sm hover:bg-cosmic-700 transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
                {t.product.title}
              </a>
              {brand.website && (
                <a
                  href={brand.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center px-4 py-2.5 border border-gray-200 text-gray-700 rounded-xl font-medium text-sm hover:bg-gray-50 transition-colors"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        </div>
      ))}

      <!-- Coming Soon Card -->
      <div class="bg-gray-50 rounded-2xl border-2 border-dashed border-gray-200 overflow-hidden flex flex-col items-center justify-center p-8 text-center">
        <div class="w-20 h-20 rounded-2xl bg-gray-100 flex items-center justify-center mb-4">
          <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-400 mb-2">
          More Brands Coming Soon
        </h3>
        <p class="text-gray-400 text-sm">
          We are expanding our brand portfolio, stay tuned
        </p>
      </div>
    </div>
  </Container>

  <!-- Brand Comparison CTA -->
  <section class="py-16 bg-gradient-to-br from-gray-50 to-gray-100">
    <Container class="text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">
        {t.filter.brandComparison}
      </h2>
      <p class="text-gray-600 mb-8">
        Compare product specifications across brands to find the best crystal oscillator solution for your application
      </p>
      <a
        href="/products"
        class="inline-flex items-center gap-2 px-6 py-3 bg-cosmic-600 text-white rounded-xl font-medium hover:bg-cosmic-700 transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
        {t.product.title}
      </a>
    </Container>
  </section>
</BaseLayout>
