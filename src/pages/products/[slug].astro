---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import { getAllProducts, type Product } from '../../data/products';

export function getStaticPaths() {
  const products = getAllProducts();
  return products.map((product: Product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;

const categoryNames = {
  oscillator: 'Crystal Oscillator (SPXO)',
  resonator: 'Crystal Resonator',
  rtc: 'RTC Module'
};

const badgeColors = {
  hot: 'bg-red-100 text-red-700',
  new: 'bg-green-100 text-green-700',
  default: 'bg-gray-100 text-gray-700',
  discontinued: 'bg-orange-100 text-orange-700',
  futures: 'bg-blue-100 text-blue-700',
};

const badgeLabels = {
  hot: 'Hot',
  new: 'New',
  default: 'Standard',
  discontinued: 'Discontinued',
  futures: 'Recommended Alternative',
};

// Get related products (same category)
const allProducts = getAllProducts();
const relatedProducts = allProducts
  .filter(p => p.category === product.category && p.id !== product.id)
  .slice(0, 4);
---

<BaseLayout
  title={`${product.model} - ${product.frequency} ${categoryNames[product.category]} | TongJing`}
  description={`${product.model} technical specifications. ${categoryNames[product.category]}, ${product.frequency}, ${product.package} package.`}
>
  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200">
    <Container>
      <nav class="flex items-center gap-2 text-sm py-3 text-gray-600">
        <a href="/" class="hover:text-cosmic-600">Home</a>
        <span>/</span>
        <a href="/products" class="hover:text-cosmic-600">Products</a>
        <span>/</span>
        <span class="text-gray-900 font-medium">{product.model}</span>
      </nav>
    </Container>
  </div>

  <!-- Product Header -->
  <section class="bg-gradient-to-r from-gray-900 to-gray-800 text-white">
    <Container class="py-10">
      <div class="flex items-start gap-6">
        <div class="w-16 h-16 bg-cosmic-600 rounded-xl flex items-center justify-center shrink-0">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
          </svg>
        </div>
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-3">
            <span class="px-2 py-0.5 text-xs bg-gray-700 text-gray-300 rounded">TongJing</span>
            <span class={`px-2 py-0.5 text-xs rounded ${
              product.category === 'oscillator' ? 'bg-blue-500 text-white' :
              product.category === 'resonator' ? 'bg-purple-500 text-white' :
              'bg-orange-500 text-white'
            }`}>
              {categoryNames[product.category]}
            </span>
            <span class={`px-2 py-0.5 text-xs rounded ${badgeColors[product.badge]}`}>
              {badgeLabels[product.badge]}
            </span>
          </div>
          <h1 class="text-2xl lg:text-3xl font-bold font-mono mb-2">{product.model}</h1>
          <p class="text-gray-400 text-sm">
            {product.specifications['Description'] || categoryNames[product.category] + ' Technical Datasheet'}
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Main Content -->
  <Container class="py-8">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">

      <!-- Left: Main Specifications -->
      <div class="lg:col-span-3 space-y-6">

        <!-- Primary Parameters Table -->
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="px-6 py-4 bg-gray-900 text-white border-b border-gray-700">
            <h2 class="font-semibold">Primary Parameters</h2>
          </div>
          <table class="w-full">
            <tbody>
              <tr class="border-b border-gray-100">
                <td class="px-6 py-4 text-gray-500 font-medium w-1/3 bg-gray-50">Model Number</td>
                <td class="px-6 py-4 font-mono font-semibold text-gray-900">{product.model}</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="px-6 py-4 text-gray-500 font-medium w-1/3 bg-gray-50">Category</td>
                <td class="px-6 py-4 text-gray-900">{categoryNames[product.category]}</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="px-6 py-4 text-gray-500 font-medium w-1/3 bg-gray-50">Nominal Frequency</td>
                <td class="px-6 py-4 text-2xl font-bold text-cosmic-600">{product.frequency}</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="px-6 py-4 text-gray-500 font-medium w-1/3 bg-gray-50">Package Size</td>
                <td class="px-6 py-4 text-gray-900">{product.package}</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="px-6 py-4 text-gray-500 font-medium w-1/3 bg-gray-50">Output Type</td>
                <td class="px-6 py-4 text-gray-900">{product.specifications['Output'] || '-'}</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="px-6 py-4 text-gray-500 font-medium w-1/3 bg-gray-50">Supply Voltage</td>
                <td class="px-6 py-4 text-gray-900">{product.specifications['Voltage'] || '-'}</td>
              </tr>
              <tr>
                <td class="px-6 py-4 text-gray-500 font-medium w-1/3 bg-gray-50">Operating Temperature</td>
                <td class="px-6 py-4 text-gray-900">{product.specifications['Operating Temp'] || '-'}</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Technical Specifications -->
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
            <h2 class="font-semibold text-gray-900">Standard Specifications</h2>
          </div>
          <table class="w-full text-sm">
            <tbody>
              <tr class="border-b border-gray-100">
                <td class="px-6 py-3 text-gray-500 w-1/3">Frequency Tolerance</td>
                <td class="px-6 py-3 text-gray-900">±50 ppm (standard), ±10 ppm, ±20 ppm available</td>
              </tr>
              <tr class="border-b border-gray-100 bg-gray-50">
                <td class="px-6 py-3 text-gray-500">Load Capacitance</td>
                <td class="px-6 py-3 text-gray-900">8 pF, 12 pF, 16 pF, 20 pF options</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="px-6 py-3 text-gray-500">Equivalent Series Resistance</td>
                <td class="px-6 py-3 text-gray-900">30 Ω - 100 Ω (depending on frequency)</td>
              </tr>
              <tr class="border-b border-gray-100 bg-gray-50">
                <td class="px-6 py-3 text-gray-500">Storage Temperature</td>
                <td class="px-6 py-3 text-gray-900">-55°C to +125°C</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="px-6 py-3 text-gray-500">Shunt Capacitance</td>
                <td class="px-6 py-3 text-gray-900">3 pF Max</td>
              </tr>
              <tr>
                <td class="px-6 py-3 text-gray-500">Drive Level</td>
                <td class="px-6 py-3 text-gray-900">100 μW Max</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Package Dimensions -->
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
            <h2 class="font-semibold text-gray-900">Package Dimensions</h2>
          </div>
          <div class="p-6">
            <div class="flex items-center gap-8">
              <!-- Package Visual -->
              <div class="w-40 h-40 bg-gradient-to-br from-gray-100 to-gray-200 rounded-xl flex items-center justify-center">
                <div class="text-center">
                  <div class="text-4xl font-bold text-gray-600">{product.package}</div>
                  <div class="text-sm text-gray-500 mt-1">SMD Package</div>
                </div>
              </div>
              <!-- Dimensions Table -->
              <div class="flex-1">
                <table class="w-full text-sm">
                  <tbody>
                    <tr class="border-b border-gray-100">
                      <td class="py-2 text-gray-500 font-medium">Length</td>
                      <td class="py-2 text-gray-900 font-semibold text-right">
                        {product.package.includes('7050') ? '7.0' :
                         product.package.includes('5032') ? '5.0' :
                         product.package.includes('3225') ? '3.2' :
                         product.package.includes('2520') ? '2.5' : '?'} mm
                      </td>
                    </tr>
                    <tr class="border-b border-gray-100">
                      <td class="py-2 text-gray-500 font-medium">Width</td>
                      <td class="py-2 text-gray-900 font-semibold text-right">
                        {product.package.includes('7050') ? '5.0' :
                         product.package.includes('5032') ? '3.2' :
                         product.package.includes('3225') ? '2.5' :
                         product.package.includes('2520') ? '2.0' : '?'} mm
                      </td>
                    </tr>
                    <tr class="border-b border-gray-100">
                      <td class="py-2 text-gray-500 font-medium">Height</td>
                      <td class="py-2 text-gray-900 font-semibold text-right">
                        {product.package.includes('7050') ? '0.8' :
                         product.package.includes('5032') ? '0.7' :
                         product.package.includes('3225') ? '0.8' :
                         product.package.includes('2520') ? '0.65' : '?'} mm
                      </td>
                    </tr>
                    <tr>
                      <td class="py-2 text-gray-500 font-medium">Package Code</td>
                      <td class="py-2 text-gray-900 font-semibold text-right font-mono">{product.package}</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Compatible Replacements -->
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
            <h2 class="font-semibold text-gray-900">Compatible Replacements</h2>
          </div>
          <div class="p-6">
            <div class="space-y-2">
              <div class="grid grid-cols-2 gap-4">
                <div class="text-sm text-gray-500">Connor-Winfield</div>
                <div class="text-sm font-mono text-gray-900">U200-25.0M</div>
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div class="text-sm text-gray-500">Abracon</div>
                <div class="text-sm font-mono text-gray-900">ASE-25.000MHz-ET</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Sidebar -->
      <div class="space-y-6">

        <!-- Stock Status -->
        <div class="bg-white rounded-xl border border-gray-200 p-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-3 h-3 bg-green-500 rounded-full"></span>
            <span class="font-semibold text-gray-900">In Stock</span>
          </div>
          <p class="text-sm text-gray-500">Production volume available</p>
        </div>

        <!-- Lifecycle Status -->
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-3 bg-gray-50 border-b border-gray-200">
            <h3 class="font-semibold text-gray-900 text-sm">Lifecycle Status</h3>
          </div>
          <div class="p-4">
            <div class="flex items-center gap-3">
              <span class="px-3 py-1 bg-green-100 text-green-700 text-sm font-medium rounded">
                Mass Production
              </span>
            </div>
            <div class="mt-4 space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500">Design</span>
                <span class="text-green-600 font-medium">Completed</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Manufacturing</span>
                <span class="text-green-600 font-medium">Active</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Testing</span>
                <span class="text-green-600 font-medium">Passed</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Key Specs Summary -->
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-3 bg-gray-50 border-b border-gray-200">
            <h3 class="font-semibold text-gray-900 text-sm">Key Parameters</h3>
          </div>
          <div class="p-4 space-y-3">
            <div class="flex justify-between items-center py-2 border-b border-gray-100">
              <span class="text-sm text-gray-500">Frequency</span>
              <span class="font-mono font-medium text-gray-900">{product.frequency}</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-gray-100">
              <span class="text-sm text-gray-500">Package</span>
              <span class="font-medium text-gray-900">{product.package}</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-gray-100">
              <span class="text-sm text-gray-500">Output</span>
              <span class="font-medium text-gray-900">{product.specifications['Output'] || '-'}</span>
            </div>
            <div class="flex justify-between items-center py-2">
              <span class="text-sm text-gray-500">Voltage</span>
              <span class="font-medium text-gray-900">{product.specifications['Voltage'] || '-'}</span>
            </div>
          </div>
        </div>

        <!-- Industries -->
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-3 bg-gray-50 border-b border-gray-200">
            <h3 class="font-semibold text-gray-900 text-sm">Target Industries</h3>
          </div>
          <div class="p-4 flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-blue-50 text-blue-700 text-sm rounded-full">Automotive Electronics</span>
            <span class="px-3 py-1 bg-purple-50 text-purple-700 text-sm rounded-full">Industrial Automation</span>
          </div>
        </div>
      </div>
    </div>
  </Container>

  <!-- Related Products -->
  {relatedProducts.length > 0 && (
    <section class="py-8 bg-gray-50 border-t border-gray-200">
      <Container>
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Related Products</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {relatedProducts.map(p => (
            <a href={`/products/${p.id}`} class="bg-white rounded-lg border border-gray-200 p-4 hover:border-cosmic-300 hover:shadow-md transition-all">
              <div class="font-mono font-semibold text-gray-900 mb-2">{p.model}</div>
              <div class="text-sm text-gray-500 space-y-1">
                <div>{p.frequency}</div>
                <div>{p.package}</div>
              </div>
            </a>
          ))}
        </div>
      </Container>
    </section>
  )}

  <!-- Back Link -->
  <div class="py-6 border-t border-gray-200">
    <Container>
      <a href="/products" class="inline-flex items-center gap-2 text-cosmic-600 hover:text-cosmic-700 font-medium">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Product Catalog
      </a>
    </Container>
  </div>
</BaseLayout>