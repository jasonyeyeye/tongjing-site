---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import ParameterGroup from '../../components/product/ParameterGroup.astro';
import CrossReference from '../../components/product/CrossReference.astro';
import ProductCard from '../../components/product/ProductCard.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import InquiryForm from '../../components/form/InquiryForm.astro';
import { useTranslations } from '../../utils/i18n';
import { getAllProducts, type Product } from '../../data/products';

const t = useTranslations();

export function getStaticPaths() {
  const products = getAllProducts();
  return products.map((product: Product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;

const parameterGroups = [
  {
    title: 'Basic Information',
    collapsible: false,
    parameters: [
      { name: 'Model', value: product.model, highlight: true },
      { name: 'Brand', value: 'TongJing' },
      { name: 'Package', value: `SMD ${product.package.replace('SMD', '')} (${product.specifications['Package'] || 'N/A'})` },
      { name: 'Packaging', value: 'Tape & reel, 3000pcs/reel' },
    ],
  },
  {
    title: 'Frequency Parameters',
    collapsible: false,
    parameters: [
      { name: 'Nominal Frequency', value: product.frequency, highlight: true },
      { name: 'Frequency Tolerance', value: product.tolerance, highlight: true },
      { name: 'Load Capacitance', value: product.loadCapacitance, highlight: true },
      { name: 'Shunt Capacitance', value: '3 pF Max' },
      { name: 'Frequency Temperature', value: product.specifications['Operating Temp'] || '-40°C to +85°C' },
    ],
  },
  {
    title: 'Electrical Parameters',
    collapsible: true,
    defaultOpen: false,
    parameters: [
      { name: 'Dynamic Resistance (RR)', value: product.esr, highlight: true },
      { name: 'Drive Level', value: '100 μW Max' },
      { name: 'Quality Factor Q', value: '40,000 Typ' },
      { name: 'Shunt Capacitance', value: '3 pF Max' },
      { name: 'Insulation Resistance', value: '500 MΩ Min' },
    ],
  },
  {
    title: 'Environmental Parameters',
    collapsible: true,
    defaultOpen: false,
    parameters: [
      { name: 'Operating Temp', value: product.specifications['Operating Temp'] || '-40°C to +85°C' },
      { name: 'Storage Temp', value: '-55°C to +125°C' },
      { name: 'Frequency Aging', value: '±3 ppm/year Max' },
      { name: 'Soldering Heat', value: '+260°C for 10 sec' },
    ],
  },
];

const certifications = ['RoHS', 'REACH', 'Halogen Free', 'AEC-Q200'];

const crossRefProducts = [
  { tongjing: 'TJ3225K-26M', epson: 'FA-238', ndk: 'NX3225GA', kds: 'DSX211G', murata: 'CRSS2012', package: '3225' },
  { tongjing: 'TJ2520K-24M', epson: 'FA-128', ndk: 'NX2520SA', kds: 'DSX210G', murata: 'CRSS1608', package: '2520' },
  { tongjing: 'TJ2016K-16M', epson: 'FA-1608', ndk: 'NX2012SA', kds: 'DSX1612G', murata: 'CRSS1210', package: '2016' },
];

const allProducts = getAllProducts();
const relatedProducts = allProducts.slice(0, 4).map((p: Product) => ({
  model: p.model,
  frequency: p.frequency,
  tolerance: p.tolerance,
  packageType: p.package,
  stock: p.stock,
  priceRange: p.priceRange,
  badge: p.badge,
  href: `/products/${p.id}`,
}));
---

<BaseLayout title={`${product.model} - ${t.seo.title}`} description={t.seo.description}>
  <!-- Breadcrumb -->
  <div class="bg-gray-50 py-3">
    <Container>
      <nav class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/" class="hover:text-gray-700">Home</a>
        <span>/</span>
        <a href="/products" class="hover:text-gray-700">Products</a>
        <span>/</span>
        <span class="text-gray-700">{product.model}</span>
      </nav>
    </Container>
  </div>

  <!-- Product Overview -->
  <section class="py-12">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Images -->
        <div>
          <div class="aspect-square bg-gray-100 rounded-xl mb-4 flex items-center justify-center">
            <svg class="w-32 h-32 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="grid grid-cols-4 gap-2">
            {[1, 2, 3, 4].map(() => (
              <div class="aspect-square bg-gray-100 rounded-lg"></div>
            ))}
          </div>
        </div>

        <!-- Info -->
        <div>
          <div class="flex items-center gap-2 mb-2">
            <Badge variant={product.badge === 'hot' ? 'hot' : product.badge === 'new' ? 'new' : 'default'}>
              {product.badge}
            </Badge>
          </div>
          <h1 class="text-2xl font-bold font-mono text-gray-800 mb-2">{product.model}</h1>
          <p class="text-gray-500 mb-6">TongJing · {product.package} ({product.specifications['Package'] || 'N/A'})</p>

          <!-- Quick Specs -->
          <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="bg-gray-50 rounded-lg p-4">
              <p class="text-xs text-gray-500 mb-1">Nominal Frequency</p>
              <p class="font-semibold text-aurora-500">{product.frequency}</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-4">
              <p class="text-xs text-gray-500 mb-1">Frequency Tolerance</p>
              <p class="font-semibold">{product.tolerance}</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-4">
              <p class="text-xs text-gray-500 mb-1">Load Capacitance</p>
              <p class="font-semibold">{product.loadCapacitance}</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-4">
              <p class="text-xs text-gray-500 mb-1">Dynamic Resistance</p>
              <p class="font-semibold">{product.esr}</p>
            </div>
          </div>

          <!-- Stock & Price -->
          <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm text-green-600 font-medium flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  In Stock
                </p>
                <p class="text-lg font-bold text-gray-800 mt-1">{product.stock}</p>
              </div>
              <div class="text-right">
                <p class="text-sm text-gray-500">Price Range</p>
                <p class="text-xl font-bold text-aurora-500">{product.priceRange}</p>
              </div>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex flex-col gap-3">
            <div class="flex gap-3">
              <div class="flex items-center border border-gray-200 rounded-lg">
                <button class="px-4 py-2 text-gray-500 hover:bg-gray-50 transition-colors">-</button>
                <input type="number" value="3000" class="w-20 text-center border-none focus:ring-0" />
                <button class="px-4 py-2 text-gray-500 hover:bg-gray-50 transition-colors">+</button>
              </div>
              <span class="flex items-center text-sm text-gray-500">pcs</span>
            </div>
            <div class="flex gap-3">
              <Button variant="primary" size="lg" class="flex-1">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                Add to Inquiry
              </Button>
              <Button variant="outline" size="lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Datasheet
              </Button>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Detailed Parameters -->
  <section class="py-12 bg-gray-50">
    <Container>
      <h2 class="text-2xl font-bold text-gray-800 mb-6">{t.product.parameters}</h2>
      <ParameterGroup groups={parameterGroups} certifications={certifications} />
    </Container>
  </section>

  <!-- Cross Reference -->
  <section class="py-12">
    <Container>
      <h2 class="text-2xl font-bold text-gray-800 mb-6">Cross Reference - Alternative Parts</h2>
      <CrossReference products={crossRefProducts} />
    </Container>
  </section>

  <!-- Related Products -->
  <section class="py-12 bg-gray-50">
    <Container>
      <h2 class="text-2xl font-bold text-gray-800 mb-6">Related Products</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {relatedProducts.map((p) => (
          <ProductCard
            model={p.model}
            frequency={p.frequency}
            tolerance={p.tolerance}
            packageType={p.packageType}
            stock={p.stock}
            priceRange={p.priceRange}
            badge={p.badge}
            href={p.href}
          />
        ))}
      </div>
    </Container>
  </section>

  <!-- Inquiry Form -->
  <section class="py-12">
    <Container>
      <div class="max-w-4xl mx-auto">
        <InquiryForm products={[{ model: product.model, quantity: 3000 }]} />
      </div>
    </Container>
  </section>
</BaseLayout>
