---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import Button from '../../components/ui/Button.astro';
import { useTranslations } from '../../utils/i18n';
import { getAllProducts, getProductBySlug, type Product } from '../../data/products';

const t = useTranslations();

export function getStaticPaths() {
  const products = getAllProducts();
  return products.map((product: Product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;

// Build specifications from Teable data
const specs = product.specifications || {};
const outputType = specs['Output'] || '';
const voltage = specs['Voltage'] || '';
const operatingTemp = specs['Operating Temp'] || '';

// Category labels
const categoryLabels = {
  oscillator: 'Crystal Oscillator (SPXO)',
  resonator: 'Crystal Resonator',
  rtc: 'RTC Module'
};

// Package description mapping
const packageDescriptions: Record<string, string> = {
  '7050': '7.0 × 5.0 mm SMD',
  '5032': '5.0 × 3.2 mm SMD',
  '3225': '3.2 × 2.5 mm SMD',
  '2520': '2.5 × 2.0 mm SMD',
};

const packageDesc = packageDescriptions[product.package] || product.package;
---

<BaseLayout
  title={`${product.model} - ${product.frequency} ${categoryLabels[product.category]} | China NewChip`}
  description={`${product.model} ${product.frequency} ${categoryLabels[product.category]}. ${product.package} package (${packageDesc}). ${voltage ? 'Voltage: ' + voltage + '. ' : ''}${outputType ? 'Output: ' + outputType + '. ' : ''}In stock. Request a quote.`}
  type="product"
>
  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200">
    <Container>
      <nav class="flex items-center gap-2 text-sm py-3 text-gray-500">
        <a href="/" class="hover:text-cosmic-600 transition-colors">Home</a>
        <span>/</span>
        <a href="/products" class="hover:text-cosmic-600 transition-colors">Products</a>
        <span>/</span>
        <span class="text-cosmic-600 font-medium">{product.model}</span>
      </nav>
    </Container>
  </div>

  <!-- Product Hero -->
  <section class="py-12">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Product Image -->
        <div class="relative">
          <div class="aspect-square rounded-2xl overflow-hidden bg-gradient-to-br from-gray-100 to-gray-50 shadow-lg">
            <img
              src={product.package.includes('7050') ? '/images/product-resonator-3225_001.jpg' :
                   product.package.includes('5032') ? '/images/product-resonator-2520_001.jpg' :
                   product.package.includes('3225') ? '/images/product-resonator-3225_001.jpg' :
                   product.package.includes('2520') ? '/images/product-resonator-2520_001.jpg' :
                   '/images/product-resonator-2016_001.jpg'}
              alt={product.model}
              class="w-full h-full object-cover"
            />
          </div>

          <!-- Badges -->
          <div class="absolute top-4 left-4 flex flex-col gap-2">
            {product.badge === 'hot' && (
              <span class="px-3 py-1.5 text-sm font-bold rounded-full bg-gradient-to-r from-red-500 to-red-600 text-white shadow-lg">
                HOT SALE
              </span>
            )}
            {product.badge === 'new' && (
              <span class="px-3 py-1.5 text-sm font-bold rounded-full bg-gradient-to-r from-green-500 to-green-600 text-white shadow-lg">
                NEW ARRIVAL
              </span>
            )}
            {product.badge === 'discontinued' && (
              <span class="px-3 py-1.5 text-sm font-bold rounded-full bg-gradient-to-r from-gray-500 to-gray-600 text-white shadow-lg">
                END OF LIFE
              </span>
            )}
          </div>

          <div class="absolute top-4 right-4">
            <span class={`px-3 py-1.5 text-sm font-medium rounded-full backdrop-blur shadow ${
              product.category === 'oscillator' ? 'bg-blue-500/90 text-white' :
              product.category === 'resonator' ? 'bg-purple-500/90 text-white' :
              'bg-orange-500/90 text-white'
            }`}>
              {categoryLabels[product.category]}
            </span>
          </div>
        </div>

        <!-- Product Info -->
        <div>
          <!-- Brand -->
          <div class="flex items-center gap-2 mb-2">
            <span class="px-2 py-0.5 bg-cosmic-100 text-cosmic-700 text-xs font-medium rounded">TongJing</span>
            <span class="text-xs text-gray-400">|</span>
            <span class="text-sm text-gray-500">Crystal Components</span>
          </div>

          <!-- Model -->
          <h1 class="text-3xl lg:text-4xl font-bold font-mono text-gray-900 mb-4">
            {product.model}
          </h1>

          <!-- Key Specs Grid -->
          <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="bg-gradient-to-br from-cosmic-50 to-cosmic-100/50 rounded-xl p-4 border border-cosmic-100">
              <span class="text-xs text-cosmic-600 font-medium block mb-1">Frequency</span>
              <span class="text-xl font-bold text-cosmic-700">{product.frequency}</span>
            </div>
            <div class="bg-gradient-to-br from-purple-50 to-purple-100/50 rounded-xl p-4 border border-purple-100">
              <span class="text-xs text-purple-600 font-medium block mb-1">Package</span>
              <span class="text-xl font-bold text-purple-700">{product.package}</span>
            </div>
            {outputType && (
              <div class="bg-gradient-to-br from-green-50 to-green-100/50 rounded-xl p-4 border border-green-100">
                <span class="text-xs text-green-600 font-medium block mb-1">Output Type</span>
                <span class="text-lg font-bold text-green-700">{outputType}</span>
              </div>
            )}
            {voltage && (
              <div class="bg-gradient-to-br from-amber-50 to-amber-100/50 rounded-xl p-4 border border-amber-100">
                <span class="text-xs text-amber-600 font-medium block mb-1">Voltage</span>
                <span class="text-lg font-bold text-amber-700">{voltage}</span>
              </div>
            )}
          </div>

          <!-- Description -->
          {product.specifications['Description'] && (
            <p class="text-gray-600 mb-6 leading-relaxed">
              {product.specifications['Description']}
            </p>
          )}

          <!-- Stock & Price -->
          <div class="bg-gradient-to-r from-green-50 to-green-100/50 border border-green-200 rounded-xl p-5 mb-6">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-green-500 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div>
                  <span class="text-green-700 font-semibold block">{product.stock}</span>
                  <span class="text-sm text-green-600">Usually ships within 2-3 days</span>
                </div>
              </div>
              <div class="text-right">
                <span class="text-sm text-gray-500 block">Price Range</span>
                <span class="text-2xl font-bold text-aurora-500">{product.priceRange}</span>
              </div>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a
              href={`/contact?model=${encodeURIComponent(product.model)}&category=${product.category}`}
              class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-gradient-to-r from-aurora-400 to-aurora-500 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
              Request Quote
            </a>
            <button class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3.5 border-2 border-gray-200 text-gray-700 font-semibold rounded-xl hover:border-cosmic-300 hover:text-cosmic-600 transition-all">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Download Datasheet
            </button>
          </div>

          <!-- Quick Info -->
          <div class="text-sm text-gray-500">
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              RoHS, REACH, Halogen Free compliant
            </span>
            <span class="flex items-center gap-2 mt-1">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Standard packaging: Tape & reel, 3000pcs/reel
            </span>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Detailed Specifications -->
  <section class="py-12 bg-gray-50">
    <Container>
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Product Specifications</h2>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Basic Parameters -->
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="bg-gradient-to-r from-cosmic-500 to-cosmic-600 text-white px-6 py-4">
            <h3 class="font-semibold text-lg">Basic Parameters</h3>
          </div>
          <div class="p-6">
            <table class="w-full">
              <tbody>
                <tr class="border-b border-gray-100">
                  <td class="py-3 text-gray-500 font-medium">Model</td>
                  <td class="py-3 text-gray-900 font-mono font-semibold text-right">{product.model}</td>
                </tr>
                <tr class="border-b border-gray-100">
                  <td class="py-3 text-gray-500 font-medium">Brand</td>
                  <td class="py-3 text-gray-900 text-right">TongJing Electronics</td>
                </tr>
                <tr class="border-b border-gray-100">
                  <td class="py-3 text-gray-500 font-medium">Category</td>
                  <td class="py-3 text-gray-900 text-right">{categoryLabels[product.category]}</td>
                </tr>
                <tr class="border-b border-gray-100">
                  <td class="py-3 text-gray-500 font-medium">Frequency</td>
                  <td class="py-3 text-cosmic-600 font-bold text-right">{product.frequency}</td>
                </tr>
                <tr class="border-b border-gray-100">
                  <td class="py-3 text-gray-500 font-medium">Package Size</td>
                  <td class="py-3 text-gray-900 text-right">{product.package} ({packageDesc})</td>
                </tr>
                {outputType && (
                  <tr class="border-b border-gray-100">
                    <td class="py-3 text-gray-500 font-medium">Output Type</td>
                    <td class="py-3 text-gray-900 text-right">{outputType}</td>
                  </tr>
                )}
                {voltage && (
                  <tr>
                    <td class="py-3 text-gray-500 font-medium">Supply Voltage</td>
                    <td class="py-3 text-gray-900 text-right">{voltage}</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Environmental Parameters -->
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
          <div class="bg-gradient-to-r from-green-500 to-green-600 text-white px-6 py-4">
            <h3 class="font-semibold text-lg">Environmental Conditions</h3>
          </div>
          <div class="p-6">
            <table class="w-full">
              <tbody>
                <tr class="border-b border-gray-100">
                  <td class="py-3 text-gray-500 font-medium">Operating Temp</td>
                  <td class="py-3 text-gray-900 text-right">{operatingTemp || '-40°C to +85°C'}</td>
                </tr>
                <tr class="border-b border-gray-100">
                  <td class="py-3 text-gray-500 font-medium">Storage Temp</td>
                  <td class="py-3 text-gray-900 text-right">-55°C to +125°C</td>
                </tr>
                <tr class="border-b border-gray-100">
                  <td class="py-3 text-gray-500 font-medium">Moisture Sensitivity</td>
                  <td class="py-3 text-gray-900 text-right">Level 1 (J-STD-020)</td>
                </tr>
                <tr>
                  <td class="py-3 text-gray-500 font-medium">RoHS Status</td>
                  <td class="py-3 text-green-600 font-medium text-right">RoHS Compliant ✓</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Alternative Products -->
  <section class="py-12">
    <Container>
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Alternative Products</h2>
      <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="text-left px-6 py-4 text-sm font-semibold text-gray-600">Brand</th>
              <th class="text-left px-6 py-4 text-sm font-semibold text-gray-600">Part Number</th>
              <th class="text-left px-6 py-4 text-sm font-semibold text-gray-600">Package</th>
              <th class="text-left px-6 py-4 text-sm font-semibold text-gray-600">Frequency</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="px-6 py-4 text-gray-600">TXC</td>
              <td class="px-6 py-4 font-mono text-gray-900">7A-25.000MEEJ-T</td>
              <td class="px-6 py-4 text-gray-600">7050</td>
              <td class="px-6 py-4 text-gray-600">25.000 MHz</td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="px-6 py-4 text-gray-600">Kyocera</td>
              <td class="px-6 py-4 font-mono text-gray-900">KC7050A250000C1E00</td>
              <td class="px-6 py-4 text-gray-600">7050</td>
              <td class="px-6 py-4 text-gray-600">25.000 MHz</td>
            </tr>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-gray-600">Connor-Winfield</td>
              <td class="px-6 py-4 font-mono text-gray-900">U200-25.0M</td>
              <td class="px-6 py-4 text-gray-600">7050</td>
              <td class="px-6 py-4 text-gray-600">25.000 MHz</td>
            </tr>
          </tbody>
        </table>
      </div>
    </Container>
  </section>

  <!-- Contact CTA -->
  <section class="py-16 bg-gradient-to-br from-cosmic-600 to-cosmic-800 text-white">
    <Container class="text-center">
      <h2 class="text-2xl lg:text-3xl font-bold mb-4">Need Technical Support or Custom Specifications?</h2>
      <p class="text-white/80 mb-8 max-w-2xl mx-auto">
        Our engineering team is ready to help you select the right crystal component for your application.
        Contact us for volume pricing and OEM partnerships.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button variant="primary" href="/contact" size="lg" class="bg-white text-cosmic-700 hover:bg-gray-100">
          Contact Technical Team
        </Button>
        <a href="/products" class="inline-flex items-center justify-center gap-2 px-6 py-3 border-2 border-white/30 text-white font-semibold rounded-xl hover:bg-white/10 transition-colors">
          Browse All Products
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>
