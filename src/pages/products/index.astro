---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import Button from '../../components/ui/Button.astro';
import { useTranslations } from '../../utils/i18n';
import { getAllProducts, type Product } from '../../data/products';

const t = useTranslations();
const allProducts = getAllProducts();

// Group products by category
const oscillators = allProducts.filter(p => p.category === 'oscillator');
const resonators = allProducts.filter(p => p.category === 'resonator');
const rtcModules = allProducts.filter(p => p.category === 'rtc');

// Serialize products for client-side filtering
const productsJson = JSON.stringify(allProducts.map(p => ({
  id: p.id,
  model: p.model,
  brand: p.brandId,
  category: p.category,
  frequency: p.frequency,
  tolerance: p.tolerance,
  package: p.package,
  specifications: p.specifications,
  stock: p.stock,
  priceRange: p.priceRange,
  badge: p.badge,
  image: p.package.includes('7050') ? '/images/product-resonator-3225_001.jpg' :
         p.package.includes('5032') ? '/images/product-resonator-2520_001.jpg' :
         p.package.includes('3225') ? '/images/product-resonator-3225_001.jpg' :
         p.package.includes('2520') ? '/images/product-resonator-2520_001.jpg' :
         '/images/product-resonator-2016_001.jpg',
  href: `/products/${p.id}`,
})));
---

<BaseLayout
  title="Electronic Components - Crystal Resonators, Oscillators, RTC Modules | China NewChip"
  description="Browse high-quality crystal resonators, oscillators, and RTC modules from TongJing. 8MHz to 50MHz, AEC-Q100 certified, global shipping."
  pageType="products"
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-cosmic-600 via-cosmic-700 to-cosmic-800 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=60 height=60 viewBox=%220 0 60 60%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cg fill=%22%23ffffff%22 fill-opacity=%220.4%22%3E%3Cpath d=%22M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>

    <Container class="py-16 relative">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/10 backdrop-blur rounded-full text-sm mb-4">
          <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
          {allProducts.length} Products Available
        </div>
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">
          Crystal Components Catalog
        </h1>
        <p class="text-lg text-white/80 mb-8">
          Professional crystal resonators, oscillators, and RTC modules from TongJing Electronics.
          High quality, competitive pricing, global delivery.
        </p>

        <div class="flex flex-wrap gap-3">
          <a href="#oscillators" class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-white/20 backdrop-blur rounded-lg transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
            </svg>
            Oscillators ({oscillators.length})
          </a>
          <a href="#resonators" class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-white/20 backdrop-blur rounded-lg transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Resonators ({resonators.length})
          </a>
          {rtcModules.length > 0 && (
            <a href="#rtc" class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-white/20 backdrop-blur rounded-lg transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              RTC Modules ({rtcModules.length})
            </a>
          )}
        </div>
      </div>
    </Container>
  </section>

  <Container class="py-12">
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 mb-8">
      <div class="flex items-center gap-4">
        <select id="category-filter" class="px-4 py-2 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-cosmic-500 focus:border-cosmic-500">
          <option value="all">All Categories</option>
          <option value="oscillator">Oscillators</option>
          <option value="resonator">Resonators</option>
          {rtcModules.length > 0 && <option value="rtc">RTC Modules</option>}
        </select>
        <select id="package-filter" class="px-4 py-2 border border-gray-200 rounded-lg bg-white focus:ring-2 focus:ring-cosmic-500 focus:border-cosmic-500">
          <option value="all">All Packages</option>
          <option value="7050">7050</option>
          <option value="5032">5032</option>
          <option value="3225">3225</option>
          <option value="2520">2520</option>
        </select>
      </div>
      <p id="product-count" class="text-sm text-gray-500">{allProducts.length} products</p>
    </div>

    <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {allProducts.map((product) => (
        <a
          href={`/products/${product.id}`}
          class="group bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-2xl hover:border-cosmic-200 hover:-translate-y-1 transition-all duration-300 overflow-hidden"
        >
          <div class="aspect-square bg-gradient-to-br from-gray-50 to-gray-100 relative overflow-hidden">
            <img
              src={product.package.includes('7050') ? '/images/product-resonator-3225_001.jpg' :
                   product.package.includes('5032') ? '/images/product-resonator-2520_001.jpg' :
                   product.package.includes('3225') ? '/images/product-resonator-3225_001.jpg' :
                   product.package.includes('2520') ? '/images/product-resonator-2520_001.jpg' :
                   '/images/product-resonator-2016_001.jpg'}
              alt={product.model}
              class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />

            <div class="absolute top-3 left-3">
              {product.badge === 'hot' && (
                <span class="px-2 py-1 text-xs font-bold rounded-full bg-gradient-to-r from-red-500 to-red-600 text-white shadow-lg">HOT</span>
              )}
              {product.badge === 'new' && (
                <span class="px-2 py-1 text-xs font-bold rounded-full bg-gradient-to-r from-green-500 to-green-600 text-white shadow-lg">NEW</span>
              )}
              {product.badge === 'discontinued' && (
                <span class="px-2 py-1 text-xs font-bold rounded-full bg-gradient-to-r from-gray-500 to-gray-600 text-white shadow-lg">EOL</span>
              )}
            </div>

            <div class="absolute top-3 right-3">
              <span class={`px-2 py-1 text-xs font-medium rounded-full backdrop-blur ${
                product.category === 'oscillator' ? 'bg-blue-500/90 text-white' :
                product.category === 'resonator' ? 'bg-purple-500/90 text-white' :
                'bg-orange-500/90 text-white'
              }`}>
                {product.category === 'oscillator' ? 'Oscillator' :
                 product.category === 'resonator' ? 'Resonator' : 'RTC'}
              </span>
            </div>
          </div>

          <div class="p-5">
            <h3 class="font-mono text-lg font-bold text-gray-900 mb-1 group-hover:text-cosmic-600 transition-colors">
              {product.model}
            </h3>
            <p class="text-sm text-gray-500 mb-4">TongJing Electronics</p>

            <div class="grid grid-cols-2 gap-2 mb-4">
              <div class="bg-gray-50 rounded-lg p-2">
                <span class="text-xs text-gray-400 block">Frequency</span>
                <span class="text-sm font-semibold text-gray-800">{product.frequency}</span>
              </div>
              <div class="bg-gray-50 rounded-lg p-2">
                <span class="text-xs text-gray-400 block">Package</span>
                <span class="text-sm font-semibold text-gray-800">{product.package}</span>
              </div>
              {product.specifications['Output'] && (
                <div class="bg-gray-50 rounded-lg p-2 col-span-2">
                  <span class="text-xs text-gray-400 block">Output Type</span>
                  <span class="text-sm font-semibold text-gray-800">{product.specifications['Output']}</span>
                </div>
              )}
              {product.specifications['Voltage'] && (
                <div class="bg-gray-50 rounded-lg p-2 col-span-2">
                  <span class="text-xs text-gray-400 block">Voltage</span>
                  <span class="text-sm font-semibold text-gray-800">{product.specifications['Voltage']}</span>
                </div>
              )}
            </div>

            <div class="flex items-center justify-between pt-3 border-t border-gray-100">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                <span class="text-sm text-green-600 font-medium">{product.stock}</span>
              </div>
              <span class="text-aurora-500 font-bold">{product.priceRange}</span>
            </div>

            <div class="mt-4">
              <span class="block w-full py-2.5 text-center bg-cosmic-50 text-cosmic-600 font-medium rounded-xl group-hover:bg-cosmic-600 group-hover:text-white transition-colors">
                View Details →
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div id="no-results" class="hidden text-center py-16">
      <svg class="w-20 h-20 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h3 class="text-xl font-semibold text-gray-800 mb-2">No products found</h3>
      <p class="text-gray-500 mb-6">Try adjusting your filter criteria</p>
      <button id="reset-filters" class="px-6 py-2.5 bg-cosmic-600 text-white rounded-xl font-medium hover:bg-cosmic-700 transition-colors">
        Reset Filters
      </button>
    </div>
  </Container>

  <section class="py-16 bg-gradient-to-br from-gray-50 to-gray-100">
    <Container>
      <div class="text-center mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Why Choose TongJing Components?</h2>
        <p class="text-gray-600">Professional quality, reliable performance</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl p-6 text-center">
          <div class="w-12 h-12 bg-cosmic-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-cosmic-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">AEC-Q100 Certified</h3>
          <p class="text-sm text-gray-600">Automotive-grade quality standards</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center">
          <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">In Stock</h3>
          <p class="text-sm text-gray-600">Ready to ship immediately</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center">
          <div class="w-12 h-12 bg-aurora-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-aurora-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Competitive Pricing</h3>
          <p class="text-sm text-gray-600">Direct from manufacturer</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Global Delivery</h3>
          <p class="text-sm text-gray-600">Worldwide shipping available</p>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-16">
    <Container class="text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Need Custom Specifications?</h2>
      <p class="text-gray-600 mb-8 max-w-2xl mx-auto">
        Contact our technical team for custom crystal components tailored to your specific requirements.
        We support volume orders and OEM partnerships.
      </p>
      <Button variant="primary" href="/contact" size="lg">
        Contact Technical Team
      </Button>
    </Container>
  </section>
</BaseLayout>

<script define:vars={{ productsJson }}>
  const products = JSON.parse(productsJson);
  const grid = document.getElementById('products-grid');
  const countEl = document.getElementById('product-count');
  const noResults = document.getElementById('no-results');
  const categoryFilter = document.getElementById('category-filter');
  const packageFilter = document.getElementById('package-filter');
  const resetBtn = document.getElementById('reset-filters');

  function filterProducts() {
    const category = categoryFilter?.value || 'all';
    const packageVal = packageFilter?.value || 'all';

    return products.filter(p => {
      if (category !== 'all' && p.category !== category) return false;
      if (packageVal !== 'all' && !p.package.includes(packageVal)) return false;
      return true;
    });
  }

  function renderProducts(productsToRender) {
    if (!grid) return;

    if (productsToRender.length === 0) {
      grid.classList.add('hidden');
      noResults?.classList.remove('hidden');
      if (countEl) countEl.textContent = '0 products';
      return;
    }

    grid.classList.remove('hidden');
    noResults?.classList.add('hidden');
    if (countEl) countEl.textContent = `${productsToRender.length} products`;

    grid.innerHTML = productsToRender.map(p => `
      <a href="${p.href}" class="group bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-2xl hover:border-cosmic-200 hover:-translate-y-1 transition-all duration-300 overflow-hidden">
        <div class="aspect-square bg-gradient-to-br from-gray-50 to-gray-100 relative overflow-hidden">
          <img src="${p.image}" alt="${p.model}" class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          <div class="absolute top-3 left-3">
            ${p.badge === 'hot' ? '<span class="px-2 py-1 text-xs font-bold rounded-full bg-gradient-to-r from-red-500 to-red-600 text-white shadow-lg">HOT</span>' : ''}
            ${p.badge === 'new' ? '<span class="px-2 py-1 text-xs font-bold rounded-full bg-gradient-to-r from-green-500 to-green-600 text-white shadow-lg">NEW</span>' : ''}
            ${p.badge === 'discontinued' ? '<span class="px-2 py-1 text-xs font-bold rounded-full bg-gradient-to-r from-gray-500 to-gray-600 text-white shadow-lg">EOL</span>' : ''}
          </div>
          <div class="absolute top-3 right-3">
            <span class="px-2 py-1 text-xs font-medium rounded-full backdrop-blur ${p.category === 'oscillator' ? 'bg-blue-500/90 text-white' : p.category === 'resonator' ? 'bg-purple-500/90 text-white' : 'bg-orange-500/90 text-white'}">
              ${p.category === 'oscillator' ? 'Oscillator' : p.category === 'resonator' ? 'Resonator' : 'RTC'}
            </span>
          </div>
        </div>
        <div class="p-5">
          <h3 class="font-mono text-lg font-bold text-gray-900 mb-1 group-hover:text-cosmic-600 transition-colors">${p.model}</h3>
          <p class="text-sm text-gray-500 mb-4">TongJing Electronics</p>
          <div class="grid grid-cols-2 gap-2 mb-4">
            <div class="bg-gray-50 rounded-lg p-2">
              <span class="text-xs text-gray-400 block">Frequency</span>
              <span class="text-sm font-semibold text-gray-800">${p.frequency}</span>
            </div>
            <div class="bg-gray-50 rounded-lg p-2">
              <span class="text-xs text-gray-400 block">Package</span>
              <span class="text-sm font-semibold text-gray-800">${p.package}</span>
            </div>
            ${p.specifications?.Output ? `<div class="bg-gray-50 rounded-lg p-2 col-span-2"><span class="text-xs text-gray-400 block">Output Type</span><span class="text-sm font-semibold text-gray-800">${p.specifications.Output}</span></div>` : ''}
            ${p.specifications?.Voltage ? `<div class="bg-gray-50 rounded-lg p-2 col-span-2"><span class="text-xs text-gray-400 block">Voltage</span><span class="text-sm font-semibold text-gray-800">${p.specifications.Voltage}</span></div>` : ''}
          </div>
          <div class="flex items-center justify-between pt-3 border-t border-gray-100">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-green-500 rounded-full"></span>
              <span class="text-sm text-green-600 font-medium">${p.stock}</span>
            </div>
            <span class="text-aurora-500 font-bold">${p.priceRange}</span>
          </div>
          <div class="mt-4">
            <span class="block w-full py-2.5 text-center bg-cosmic-50 text-cosmic-600 font-medium rounded-xl group-hover:bg-cosmic-600 group-hover:text-white transition-colors">View Details →</span>
          </div>
        </div>
      </a>
    `).join('');
  }

  categoryFilter?.addEventListener('change', () => renderProducts(filterProducts()));
  packageFilter?.addEventListener('change', () => renderProducts(filterProducts()));

  resetBtn?.addEventListener('click', () => {
    if (categoryFilter) categoryFilter.value = 'all';
    if (packageFilter) packageFilter.value = 'all';
    renderProducts(filterProducts());
  });

  renderProducts(filterProducts());
</script>
