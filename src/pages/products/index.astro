---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import { getAllProducts, type Product } from '../../data/products';

const allProducts = getAllProducts();

// Group by category
const oscillators = allProducts.filter(p => p.category === 'oscillator');
const resonators = allProducts.filter(p => p.category === 'resonator');
const rtcModules = allProducts.filter(p => p.category === 'rtc');

// Serialize for client-side
const productsJson = JSON.stringify(allProducts.map(p => ({
  id: p.id,
  model: p.model,
  category: p.category,
  frequency: p.frequency,
  package: p.package,
  specifications: p.specifications,
  badge: p.badge,
})));
---

<BaseLayout
  title="Product Catalog - Crystal Resonators, Oscillators, RTC Modules | TongJing"
  description="Complete product catalog for TongJing crystal resonators, oscillators, and RTC modules. Technical specifications for product selection."
>
  <!-- Header -->
  <section class="bg-gray-900 text-white">
    <Container class="py-12">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 bg-cosmic-500 rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
          </svg>
        </div>
        <span class="text-sm text-gray-400">TongJing Electronics</span>
      </div>
      <h1 class="text-3xl font-bold mb-2">Product Technical Catalog</h1>
      <p class="text-gray-400">Complete specifications for crystal resonators, oscillators, and RTC modules</p>
    </Container>
  </section>

  <!-- Stats Bar -->
  <div class="bg-gray-800 text-white border-b border-gray-700">
    <Container>
      <div class="flex flex-wrap gap-8 py-4 text-sm">
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 bg-blue-400 rounded-full"></span>
          <span class="text-gray-300">Oscillators</span>
          <span class="font-semibold">{oscillators.length}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 bg-purple-400 rounded-full"></span>
          <span class="text-gray-300">Resonators</span>
          <span class="font-semibold">{resonators.length}</span>
        </div>
        {rtcModules.length > 0 && (
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 bg-orange-400 rounded-full"></span>
            <span class="text-gray-300">RTC Modules</span>
            <span class="font-semibold">{rtcModules.length}</span>
          </div>
        )}
      </div>
    </Container>
  </div>

  <!-- Filter Section -->
  <div class="bg-gray-50 border-b border-gray-200">
    <Container class="py-4">
      <div class="flex flex-wrap items-center gap-4">
        <span class="text-sm font-medium text-gray-700">Filter:</span>
        <select id="category-filter" class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg bg-white focus:ring-2 focus:ring-cosmic-500 focus:border-cosmic-500">
          <option value="all">All Categories</option>
          <option value="oscillator">Oscillators</option>
          <option value="resonator">Resonators</option>
          {rtcModules.length > 0 && <option value="rtc">RTC Modules</option>}
        </select>
        <select id="package-filter" class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg bg-white focus:ring-2 focus:ring-cosmic-500 focus:border-cosmic-500">
          <option value="all">All Packages</option>
          <option value="7050">7050</option>
          <option value="5032">5032</option>
          <option value="3225">3225</option>
          <option value="2520">2520</option>
        </select>
        <button id="reset-btn" class="px-3 py-1.5 text-sm text-cosmic-600 hover:text-cosmic-700 font-medium">
          Reset
        </button>
      </div>
    </Container>
  </div>

  <!-- Products Table -->
  <Container class="py-8">
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <!-- Table Header -->
      <div class="grid grid-cols-12 gap-4 px-6 py-3 bg-gray-100 border-b border-gray-200 text-sm font-semibold text-gray-600">
        <div class="col-span-2">Model</div>
        <div class="col-span-1">Category</div>
        <div class="col-span-2">Frequency</div>
        <div class="col-span-1">Package</div>
        <div class="col-span-2">Output Type</div>
        <div class="col-span-2">Voltage</div>
        <div class="col-span-2">Operating Temp</div>
      </div>

      <!-- Table Body -->
      <div id="products-table">
        {allProducts.map((product) => (
          <a
            href={`/products/${product.id}`}
            class="grid grid-cols-12 gap-4 px-6 py-4 border-b border-gray-100 hover:bg-cosmic-50 transition-colors items-center"
          >
            <div class="col-span-2">
              <span class="font-mono font-semibold text-gray-900 hover:text-cosmic-600">
                {product.model}
              </span>
            </div>
            <div class="col-span-1">
              <span class={`inline-block px-2 py-0.5 text-xs font-medium rounded ${
                product.category === 'oscillator' ? 'bg-blue-100 text-blue-700' :
                product.category === 'resonator' ? 'bg-purple-100 text-purple-700' :
                'bg-orange-100 text-orange-700'
              }`}>
                {product.category === 'oscillator' ? 'Osc' :
                 product.category === 'resonator' ? 'Res' : 'RTC'}
              </span>
            </div>
            <div class="col-span-2 text-gray-700 font-mono">
              {product.frequency}
            </div>
            <div class="col-span-1 text-gray-700">
              {product.package}
            </div>
            <div class="col-span-2 text-gray-600 text-sm">
              {product.specifications['Output'] || '-'}
            </div>
            <div class="col-span-2 text-gray-600 text-sm">
              {product.specifications['Voltage'] || '-'}
            </div>
            <div class="col-span-2 text-gray-600 text-sm">
              {product.specifications['Operating Temp'] || '-40°C to +85°C'}
            </div>
          </a>
        ))}
      </div>

      <!-- No Results -->
      <div id="no-results" class="hidden py-12 text-center">
        <p class="text-gray-500">No products match the selected filters</p>
        <button id="reset-btn-2" class="mt-4 px-4 py-2 text-cosmic-600 font-medium hover:text-cosmic-700">
          Reset Filters
        </button>
      </div>
    </div>

    <!-- Count -->
    <p id="count-text" class="mt-4 text-sm text-gray-500">{allProducts.length} products</p>
  </Container>

  <!-- Parameter Notes -->
  <section class="py-8 bg-gray-50">
    <Container>
      <h2 class="text-lg font-semibold text-gray-800 mb-4">Parameter Definitions</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-sm">
        <div class="bg-white rounded-lg p-4 border border-gray-200">
          <h3 class="font-medium text-gray-900 mb-2">Frequency</h3>
          <p class="text-gray-600">Nominal oscillation frequency. Measured at 25°C unless otherwise specified.</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-gray-200">
          <h3 class="font-medium text-gray-900 mb-2">Output Type</h3>
          <p class="text-gray-600">CMOS, LVPECL, LVDS, Clipped Sine - determines the output signal format.</p>
        </div>
        <div class="bg-white rounded-lg p-4 border border-gray-200">
          <h3 class="font-medium text-gray-900 mb-2">Package Size</h3>
          <p class="text-gray-600">SMD package dimensions in tenths of millimeters. E.g., 3225 = 3.2×2.5×0.8mm</p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

<script define:vars={{ productsJson }}>
  const products = JSON.parse(productsJson);
  const table = document.getElementById('products-table');
  const countText = document.getElementById('count-text');
  const noResults = document.getElementById('no-results');
  const categoryFilter = document.getElementById('category-filter');
  const packageFilter = document.getElementById('package-filter');
  const resetBtn = document.getElementById('reset-btn');
  const resetBtn2 = document.getElementById('reset-btn-2');

  function filterProducts() {
    const category = categoryFilter?.value || 'all';
    const packageVal = packageFilter?.value || 'all';

    return products.filter(p => {
      if (category !== 'all' && p.category !== category) return false;
      if (packageVal !== 'all' && !p.package.includes(packageVal)) return false;
      return true;
    });
  }

  function renderProducts(filtered) {
    if (!table) return;

    if (filtered.length === 0) {
      table.classList.add('hidden');
      noResults?.classList.remove('hidden');
      if (countText) countText.textContent = '0 products';
      return;
    }

    table.classList.remove('hidden');
    noResults?.classList.add('hidden');
    if (countText) countText.textContent = `${filtered.length} products`;

    table.innerHTML = filtered.map(p => `
      <a href="/products/${p.id}" class="grid grid-cols-12 gap-4 px-6 py-4 border-b border-gray-100 hover:bg-cosmic-50 transition-colors items-center">
        <div class="col-span-2">
          <span class="font-mono font-semibold text-gray-900 hover:text-cosmic-600">${p.model}</span>
        </div>
        <div class="col-span-1">
          <span class="inline-block px-2 py-0.5 text-xs font-medium rounded ${
            p.category === 'oscillator' ? 'bg-blue-100 text-blue-700' :
            p.category === 'resonator' ? 'bg-purple-100 text-purple-700' :
            'bg-orange-100 text-orange-700'
          }">
            ${p.category === 'oscillator' ? 'Osc' : p.category === 'resonator' ? 'Res' : 'RTC'}
          </span>
        </div>
        <div class="col-span-2 text-gray-700 font-mono">${p.frequency}</div>
        <div class="col-span-1 text-gray-700">${p.package}</div>
        <div class="col-span-2 text-gray-600 text-sm">${p.specifications?.Output || '-'}</div>
        <div class="col-span-2 text-gray-600 text-sm">${p.specifications?.Voltage || '-'}</div>
        <div class="col-span-2 text-gray-600 text-sm">${p.specifications?.['Operating Temp'] || '-40°C to +85°C'}</div>
      </a>
    `).join('');
  }

  function resetFilters() {
    if (categoryFilter) categoryFilter.value = 'all';
    if (packageFilter) packageFilter.value = 'all';
    renderProducts(filterProducts());
  }

  categoryFilter?.addEventListener('change', () => renderProducts(filterProducts()));
  packageFilter?.addEventListener('change', () => renderProducts(filterProducts()));
  resetBtn?.addEventListener('click', resetFilters);
  resetBtn2?.addEventListener('click', resetFilters);
</script>
