---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/layout/Container.astro';
import ProductCard from '../components/product/ProductCard.astro';
import Button from '../components/ui/Button.astro';

interface FeaturedProduct {
  model: string;
  frequency: string;
  tolerance: string;
  packageType: string;
  loadCapacitance: string;
  esr: string;
  stock: string;
  priceRange: string;
  badge: 'hot' | 'new' | 'default' | 'discontinued' | 'futures';
  image?: string;
  href: string;
}

const featuredProducts: FeaturedProduct[] = [
  {
    model: 'TJ3225K-26.000M',
    frequency: '26MHz',
    tolerance: '±10ppm',
    packageType: 'SMD3225',
    loadCapacitance: '12pF',
    esr: '30Ω',
    stock: '500,000 PCS',
    priceRange: '$0.08 - $0.12',
    badge: 'hot',
    image: '/images/product-resonator-3225_001.jpg',
    href: '/products/tongjing-tj3225k',
  },
  {
    model: 'TJ2520K-24.000M',
    frequency: '24MHz',
    tolerance: '±20ppm',
    packageType: 'SMD2520',
    loadCapacitance: '12pF',
    esr: '40Ω',
    stock: '320,000 PCS',
    priceRange: '$0.07 - $0.10',
    badge: 'new',
    image: '/images/product-resonator-2520_001.jpg',
    href: '/products/tongjing-tj2520k',
  },
  {
    model: 'TJ2016K-16.000M',
    frequency: '16MHz',
    tolerance: '±10ppm',
    packageType: 'SMD2016',
    loadCapacitance: '8pF',
    esr: '50Ω',
    stock: '180,000 PCS',
    priceRange: '$0.06 - $0.09',
    badge: 'default',
    image: '/images/product-resonator-2016_001.jpg',
    href: '/products/tongjing-tj2016k',
  },
  {
    model: 'TJ3225O-25.000M',
    frequency: '25MHz',
    tolerance: '±50ppm',
    packageType: 'SMD3225',
    loadCapacitance: '20pF',
    esr: '30Ω',
    stock: 'Futures 2 weeks',
    badge: 'futures',
    image: '/images/product-resonator-3225_001.jpg',
    href: '/products/tongjing-tj3225o',
  },
];

interface Feature {
  icon: string;
  titleKey: string;
  descKey: string;
}

const features: Feature[] = [
  { icon: '🏭', titleKey: 'about.smartManuf', descKey: 'about.smartManufDesc' },
  { icon: '⚡', titleKey: 'about.certQuality', descKey: 'about.certQualityDesc' },
  { icon: '🎯', titleKey: 'about.directFromMfg', descKey: 'about.directFromMfgDesc' },
  { icon: '🔬', titleKey: 'about.globalDist', descKey: 'about.globalDistDesc' },
];

const featureTitles: Record<string, string> = {
  'about.smartManuf': 'Smart Manufacturing',
  'about.certQuality': 'Certified Quality',
  'about.directFromMfg': 'Direct from Manufacturer',
  'about.globalDist': 'Global Distribution',
};

const featureDescs: Record<string, string> = {
  'about.smartManufDesc': 'State-of-the-art automated production lines with 100M+ monthly capacity',
  'about.certQualityDesc': 'ISO9001, ISO14001, AEC-Q100 certified products meeting international standards',
  'about.directFromMfgDesc': 'No middlemen — factory-direct pricing and supply chain transparency',
  'about.globalDistDesc': 'Serving 50+ countries with reliable logistics and technical support',
};
---

<BaseLayout
  title="China NewChip - Electronic Components & Chinese Chip Brands Platform"
  description="Discover leading Chinese electronics brands and electronic components. Sourcing high-quality semiconductors, crystal resonators, oscillators from certified manufacturers in China. Global shipping available."
  pageType="home"
>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-cosmic-600 to-cosmic-800 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=60 height=60 viewBox=%220 0 60 60%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cg fill=%22%239C92AC%22 fill-opacity=%220.4%22%3E%3Cpath d=%22M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <Container class="relative py-20 lg:py-32">
      <div class="max-w-6xl">
        <h1 class="text-4xl lg:text-5xl font-bold mb-6 leading-tight" data-i18n="hero.title">
          Leading Chinese Electronics Brands, Global Quality Standards
        </h1>
        <p class="text-xl text-white/80 mb-8 leading-relaxed" data-i18n="hero.subtitle">
          China NewChip connects you with top-tier electronic component manufacturers in China — semiconductors, crystal resonators, oscillators, and more — serving clients in 50+ countries
        </p>
        <div class="flex flex-wrap gap-4">
          <Button variant="primary" size="lg" href="/products">
            <span data-i18n="hero.cta">Explore Products</span>
          </Button>
          <Button variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-cosmic-600" href="/contact">
            <span data-i18n="hero.ctaSecondary">Contact Us</span>
          </Button>
        </div>
      </div>
    </Container>
  </section>

  <!-- Why Choose Us -->
  <section class="py-20 bg-gray-50">
    <Container>
      <h2 class="text-3xl font-bold text-center text-gray-800 mb-12">Core Advantages</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map((feature) => (
          <div class="bg-white rounded-xl p-6 text-center shadow-sm hover:shadow-lg transition-shadow">
            <div class="text-4xl mb-4">{feature.icon}</div>
            <h3 class="text-lg font-semibold text-gray-800 mb-2" data-i18n={feature.titleKey}>{featureTitles[feature.titleKey]}</h3>
            <p class="text-sm text-gray-500" data-i18n={feature.descKey}>{featureDescs[feature.descKey]}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Product Categories -->
  <section class="py-20">
    <Container>
      <h2 class="text-3xl font-bold text-center text-gray-800 mb-12" data-i18n="product.title">Electronic Components & Chips</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <a href="/products" class="group bg-gray-50 rounded-xl overflow-hidden hover:shadow-xl transition-all">
          <div class="aspect-video overflow-hidden">
            <img src="/images/category-resonator_001.jpg" alt="Crystal Resonators" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-800 group-hover:text-cosmic-600 transition-colors mb-2" data-i18n="product.resonators">
              Crystal Resonators
            </h3>
            <p class="text-sm text-gray-500 mb-4">Crystal Resonator</p>
            <p class="text-sm text-gray-400">3225 / 2520 / 2016 Package</p>
            <span class="inline-flex items-center text-cosmic-500 text-sm font-medium mt-4 group-hover:translate-x-2 transition-transform">
              <span data-i18n="product.viewDetail">View Details</span>
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>

        <a href="/products" class="group bg-gray-50 rounded-xl overflow-hidden hover:shadow-xl transition-all">
          <div class="aspect-video overflow-hidden">
            <img src="/images/category-oscillator_001.jpg" alt="Crystal Oscillators" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-800 group-hover:text-aurora-500 transition-colors mb-2" data-i18n="product.oscillators">
              Crystal Oscillators
            </h3>
            <p class="text-sm text-gray-500 mb-4">Crystal Oscillator</p>
            <p class="text-sm text-gray-400">Precision up to ±10ppm</p>
            <span class="inline-flex items-center text-aurora-500 text-sm font-medium mt-4 group-hover:translate-x-2 transition-transform">
              <span data-i18n="product.viewDetail">View Details</span>
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>

        <a href="/products" class="group bg-gray-50 rounded-xl overflow-hidden hover:shadow-xl transition-all">
          <div class="aspect-video overflow-hidden">
            <img src="/images/category-rtc_001.jpg" alt="RTC Modules" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-800 group-hover:text-cosmic-600 transition-colors mb-2" data-i18n="product.rtc">
              RTC Modules
            </h3>
            <p class="text-sm text-gray-500 mb-4">Real-Time Clock Module</p>
            <p class="text-sm text-gray-400">Low power consumption</p>
            <span class="inline-flex items-center text-cosmic-500 text-sm font-medium mt-4 group-hover:translate-x-2 transition-transform">
              <span data-i18n="product.viewDetail">View Details</span>
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </a>
      </div>
    </Container>
  </section>

  <!-- Featured Products -->
  <section class="py-20 bg-gray-50">
    <Container>
      <h2 class="text-3xl font-bold text-center text-gray-800 mb-12">Featured Products</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featuredProducts.map((product) => (
          <ProductCard
            model={product.model}
            frequency={product.frequency}
            tolerance={product.tolerance}
            packageType={product.packageType}
            loadCapacitance={product.loadCapacitance}
            esr={product.esr}
            stock={product.stock}
            priceRange={product.priceRange}
            badge={product.badge}
            image={product.image}
            href={product.href}
          />
        ))}
      </div>
      <div class="text-center mt-10">
        <Button variant="outline" href="/products">
          <span data-i18n="common.viewAll">View All Products</span>
        </Button>
      </div>
    </Container>
  </section>

  <!-- Brands -->
  <section class="py-20">
    <Container>
      <h2 class="text-3xl font-bold text-center text-gray-800 mb-12">Our Brands</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <a href="/brands" class="group bg-white rounded-xl p-8 border border-gray-200 hover:border-cosmic-300 hover:shadow-lg transition-all text-center">
          <div class="w-16 h-16 mx-auto mb-4 bg-gradient-to-br from-cosmic-500 to-cosmic-700 rounded-xl flex items-center justify-center">
            <span class="text-2xl font-bold text-white">TJ</span>
          </div>
          <h3 class="font-semibold text-gray-800 group-hover:text-cosmic-600">TongJing</h3>
          <p class="text-sm text-gray-500 mt-1">Crystal Resonators</p>
        </a>
        <a href="/brands" class="group bg-white rounded-xl p-8 border border-gray-200 hover:border-cosmic-300 hover:shadow-lg transition-all text-center">
          <div class="w-16 h-16 mx-auto mb-4 bg-gradient-to-br from-aurora-400 to-aurora-600 rounded-xl flex items-center justify-center">
            <span class="text-2xl font-bold text-white">NC</span>
          </div>
          <h3 class="font-semibold text-gray-800 group-hover:text-cosmic-600">NewChip</h3>
          <p class="text-sm text-gray-500 mt-1">Oscillators</p>
        </a>
        <a href="/brands" class="group bg-white rounded-xl p-8 border border-gray-200 hover:border-cosmic-300 hover:shadow-lg transition-all text-center">
          <div class="w-16 h-16 mx-auto mb-4 bg-gradient-to-br from-purple-500 to-purple-700 rounded-xl flex items-center justify-center">
            <span class="text-2xl font-bold text-white">XT</span>
          </div>
          <h3 class="font-semibold text-gray-800 group-hover:text-cosmic-600">XTaltek</h3>
          <p class="text-sm text-gray-500 mt-1">RTC Modules</p>
        </a>
        <a href="/brands" class="group bg-white rounded-xl p-8 border border-gray-200 hover:border-cosmic-300 hover:shadow-lg transition-all text-center">
          <div class="w-16 h-16 mx-auto mb-4 bg-gradient-to-br from-green-500 to-green-700 rounded-xl flex items-center justify-center">
            <span class="text-2xl font-bold text-white">CQ</span>
          </div>
          <h3 class="font-semibold text-gray-800 group-hover:text-cosmic-600">ChipQuik</h3>
          <p class="text-sm text-gray-500 mt-1">Components</p>
        </a>
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gradient-to-br from-cosmic-600 to-cosmic-800 text-white">
    <Container class="text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to get started?</h2>
      <p class="text-white/80 mb-8 max-w-2xl mx-auto">Contact our team for technical support, custom solutions, or product inquiries. We're here to help you find the right components for your application.</p>
      <div class="flex justify-center gap-4">
        <Button variant="primary" size="lg" class="bg-white text-cosmic-600 hover:bg-gray-100" href="/contact">
          Contact Us
        </Button>
        <Button variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-cosmic-600" href="/products">
          Browse Products
        </Button>
      </div>
    </Container>
  </section>
</BaseLayout>